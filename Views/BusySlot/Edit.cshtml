@model ExamInvigilationManagement.Application.DTOs.LecturerBusySlot.LecturerBusySlotDto

@{
    ViewData["Title"] = "Edit Busy Slot";
}

<form asp-action="Edit" method="post">

    <input type="hidden" asp-for="Id" />

    <div class="form-page">

        @await Html.PartialAsync("_FormHeader")

        <div class="form-card busy-slot-form-card">
            <div class="busy-slot-form-grid">

            <div class="form-group">
                <label>Ngày bận</label>
                <input asp-for="BusyDate" type="date" class="input-modern" />
            </div>

            <div class="form-group">
                <label>Ca thi</label>
                <input asp-for="ExamSlotId" class="input-modern" />
            </div>

            <div class="form-group busy-slot-note-field">
                <label>Ghi chú</label>
                <textarea asp-for="Note" class="input-modern"></textarea>
            </div>

            </div>

            @await Html.PartialAsync("_FormFooter")

        </div>

    </div>

</form>

<style>
    .busy-slot-form-card {
        max-width: 980px;
    }

    .busy-slot-form-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 14px 16px;
    }

    .busy-slot-form-grid .form-group {
        margin-bottom: 0;
    }

    .busy-slot-note-field {
        grid-column: 1 / -1;
    }

    .busy-slot-note-field textarea {
        min-height: 92px;
    }

    @@media (max-width: 768px) {
        .busy-slot-form-grid {
            grid-template-columns: 1fr;
        }
    }
</style>
