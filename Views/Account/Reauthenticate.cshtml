@model ExamInvigilationManagement.Application.DTOs.LoginRequestDto

@{
    Layout = null;
    var returnUrl = ViewBag.ReturnUrl as string;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Xác thực lại | Exam Invigilation Management</title>
    <style>
        * { box-sizing: border-box; }

        body {
            margin: 0;
            min-height: 100vh;
            display: grid;
            place-items: center;
            padding: 24px;
            font-family: "Segoe UI", Arial, sans-serif;
            color: #102a43;
            background:
                radial-gradient(circle at 14% 18%, rgba(15, 118, 110, 0.2), transparent 28%),
                radial-gradient(circle at 84% 12%, rgba(14, 116, 144, 0.18), transparent 24%),
                linear-gradient(135deg, #f8fafc 0%, #e0f2fe 55%, #f0fdfa 100%);
        }

        .auth-card {
            width: min(100%, 430px);
            padding: 34px;
            border-radius: 28px;
            background: #fff;
            box-shadow: 0 28px 90px rgba(15, 23, 42, 0.14);
        }

        .badge {
            display: inline-flex;
            align-items: center;
            margin-bottom: 18px;
            padding: 8px 12px;
            border-radius: 999px;
            background: #ecfeff;
            color: #0e7490;
            font-size: 13px;
            font-weight: 750;
        }

        h1 {
            margin: 0 0 8px;
            font-size: 27px;
            letter-spacing: -0.035em;
            color: #0f172a;
        }

        .subtitle {
            margin: 0 0 24px;
            color: #64748b;
            line-height: 1.6;
        }

        .validation-summary-errors {
            margin: 0 0 18px;
            padding: 13px 14px;
            border-radius: 16px;
            border: 1px solid rgba(220, 38, 38, 0.18);
            background: #fef2f2;
            color: #991b1b;
            font-size: 14px;
        }

        .validation-summary-errors ul { margin: 0; padding-left: 18px; }

        .form-field { margin-bottom: 18px; }

        label {
            display: block;
            margin-bottom: 8px;
            font-size: 14px;
            font-weight: 650;
            color: #334155;
        }

        input {
            width: 100%;
            height: 48px;
            padding: 0 14px;
            border: 1px solid #cbd5e1;
            border-radius: 14px;
            outline: none;
            background: #f8fafc;
            color: #0f172a;
            font-size: 15px;
        }

        input:focus {
            border-color: #0f766e;
            background: #fff;
            box-shadow: 0 0 0 4px rgba(15, 118, 110, 0.12);
        }

        .field-validation-error {
            display: block;
            margin-top: 6px;
            color: #b91c1c;
            font-size: 13px;
        }

        .btn-submit {
            width: 100%;
            height: 50px;
            border: 0;
            border-radius: 16px;
            color: #fff;
            cursor: pointer;
            font-size: 15px;
            font-weight: 750;
            background: linear-gradient(135deg, #0f766e, #0e7490);
            box-shadow: 0 16px 34px rgba(15, 118, 110, 0.28);
        }
    </style>
</head>
<body>
    <main class="auth-card">
        <div class="badge">Step-up authentication</div>
        <h1>Xác thực lại</h1>
        <p class="subtitle">Thao tác này nhạy cảm. Vui lòng nhập lại mật khẩu để tiếp tục.</p>

        @using (Html.BeginForm("Reauthenticate", "Account", new { returnUrl }, FormMethod.Post))
        {
            @Html.AntiForgeryToken()
            @Html.ValidationSummary(false, "", new { @class = "validation-summary-errors" })
            @Html.HiddenFor(m => m.UserName)

            <div class="form-field">
                <label>Tài khoản</label>
                <input value="@Model.UserName" disabled />
            </div>

            <div class="form-field">
                <label for="Password">Mật khẩu</label>
                @Html.PasswordFor(m => m.Password, new { autocomplete = "current-password", required = "required", autofocus = "autofocus", placeholder = "Nhập mật khẩu hiện tại" })
                @Html.ValidationMessageFor(m => m.Password)
            </div>

            <button type="submit" class="btn-submit">Xác thực và tiếp tục</button>
        }
    </main>
</body>
</html>
