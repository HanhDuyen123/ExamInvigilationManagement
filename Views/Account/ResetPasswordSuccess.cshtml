@{
    ViewData["Title"] = "Thành công";
    Layout = null;
}

<div style="text-align:center; margin-top:50px;">
    <h2 style="color:green;">✅ Đã cập nhật mật khẩu thành công!</h2>
    <p>Bạn sẽ được chuyển về trang đăng nhập sau <span id="countdown">5</span> giây...</p>

    <a href="/Account/Login">Bấm vào đây nếu không tự chuyển</a>
</div>

<script>
    let time = 5;
    const countdown = document.getElementById("countdown");

    const interval = setInterval(() => {
        time--;
        countdown.innerText = time;

        if (time <= 0) {
            clearInterval(interval);
            window.location.href = "/Account/Login";
        }
    }, 1000);
</script>