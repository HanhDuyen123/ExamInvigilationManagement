@model ExamInvigilationManagement.Application.DTOs.LoginRequestDto

@{
    Layout = null;
    var returnUrl = ViewBag.ReturnUrl as string;
    var notifyType = TempData["Notify.Type"] as string;
    var notifyMessage = TempData["Notify.Message"] as string;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Đăng nhập | Hệ thống quản lý coi thi</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@600;700;800;900&family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            min-height: 100vh;
            font-family: "Inter", "Segoe UI", Arial, sans-serif;
            color: #102a43;
            background:
                radial-gradient(circle at 12% 20%, rgba(17, 94, 89, 0.2), transparent 28%),
                radial-gradient(circle at 88% 18%, rgba(37, 99, 235, 0.16), transparent 24%),
                linear-gradient(135deg, #f8fafc 0%, #e0f2fe 52%, #f0fdfa 100%);
        }

        .auth-shell {
            min-height: 100vh;
            display: grid;
            grid-template-columns: minmax(0, 1fr) 440px;
            align-items: stretch;
        }

        .brand-panel {
            padding: 46px 56px;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
        }

        .brand-mark {
            display: inline-flex;
            align-items: center;
            gap: 12px;
            font-weight: 700;
            letter-spacing: -0.02em;
            color: #0f766e;
            font-family: "Be Vietnam Pro", "Segoe UI", sans-serif;
        }

        .brand-logo {
            width: 78px;
            height: 78px;
            border-radius: 50%;
            display: block;
            object-fit: contain;
            background: #fff;
            border: 1px solid rgba(15, 118, 110, 0.16);
            box-shadow: 0 16px 32px rgba(15, 118, 110, 0.22);
        }

        .hero-copy {
            max-width: 640px;
        }

        .hero-copy h1 {
            margin: 0 0 14px;
            font-size: clamp(32px, 4.4vw, 54px);
            line-height: 1.02;
            letter-spacing: -0.055em;
            color: #0f172a;
        }

        .hero-copy p {
            margin: 0;
            max-width: 520px;
            color: #475569;
            font-size: 17px;
            line-height: 1.7;
        }

        .auth-panel {
            display: flex;
            align-items: center;
            padding: 24px 32px;
            background: rgba(255, 255, 255, 0.72);
            border-left: 1px solid rgba(148, 163, 184, 0.25);
            backdrop-filter: blur(20px);
        }

        .auth-card {
            width: 100%;
            padding: 28px 32px;
            border-radius: 24px;
            background: #ffffff;
            box-shadow: 0 28px 90px rgba(15, 23, 42, 0.14);
        }

        .auth-card h2 {
            margin: 0 0 6px;
            font-size: 26px;
            letter-spacing: -0.035em;
            color: #0f172a;
        }

        .auth-card .subtitle {
            margin: 0 0 20px;
            color: #64748b;
            line-height: 1.55;
        }

        .validation-summary-errors,
        .auth-alert {
            margin: 0 0 14px;
            padding: 10px 12px;
            border-radius: 16px;
            border: 1px solid rgba(220, 38, 38, 0.18);
            background: #fef2f2;
            color: #991b1b;
            font-size: 14px;
            line-height: 1.5;
        }

        .validation-summary-errors ul {
            margin: 0;
            padding-left: 18px;
        }

        .auth-notice {
            margin: 0 0 14px;
            padding: 10px 12px;
            border-radius: 16px;
            font-size: 14px;
            line-height: 1.5;
        }

        .auth-notice.success {
            border: 1px solid rgba(22, 163, 74, 0.2);
            background: #f0fdf4;
            color: #166534;
        }

        .auth-notice.error {
            border: 1px solid rgba(220, 38, 38, 0.18);
            background: #fef2f2;
            color: #991b1b;
        }

        .form-field {
            margin-bottom: 14px;
        }

        .form-field label {
            display: block;
            margin-bottom: 6px;
            font-size: 14px;
            font-weight: 650;
            color: #334155;
        }

        .input-wrap {
            position: relative;
        }

        .input-wrap input {
            width: 100%;
            height: 44px;
            padding: 0 44px 0 14px;
            border: 1px solid #cbd5e1;
            border-radius: 14px;
            outline: none;
            background: #f8fafc;
            color: #0f172a;
            font-size: 15px;
            transition: border-color 0.18s ease, box-shadow 0.18s ease, background 0.18s ease;
        }

        .input-wrap input:focus {
            border-color: #0f766e;
            background: #fff;
            box-shadow: 0 0 0 4px rgba(15, 118, 110, 0.12);
        }

        .toggle-password {
            position: absolute;
            right: 10px;
            top: 50%;
            transform: translateY(-50%);
            border: 0;
            background: transparent;
            color: #0f766e;
            cursor: pointer;
            font-weight: 650;
        }

        .field-validation-error {
            display: block;
            margin-top: 6px;
            color: #b91c1c;
            font-size: 13px;
        }

        .form-row {
            display: flex;
            justify-content: flex-end;
            margin: 0 0 16px;
        }

        .link {
            color: #0f766e;
            text-decoration: none;
            font-weight: 650;
            font-size: 14px;
        }

        .link:hover {
            text-decoration: underline;
        }

        .btn-login {
            width: 100%;
            height: 46px;
            border: 0;
            border-radius: 16px;
            color: #fff;
            cursor: pointer;
            font-size: 15px;
            font-weight: 750;
            background: linear-gradient(135deg, #0f766e, #0e7490);
            box-shadow: 0 16px 34px rgba(15, 118, 110, 0.28);
        }

        .btn-login:hover {
            filter: brightness(1.03);
        }

        .mobile-note {
            display: none;
            margin: 0 0 24px;
            color: #64748b;
            line-height: 1.5;
        }

        @@media (max-width: 860px) {
            .auth-shell {
                grid-template-columns: 1fr;
            }

            .brand-panel {
                display: none;
            }

            .auth-panel {
                min-height: 100vh;
                padding: 16px;
                border-left: 0;
            }

            .auth-card {
                padding: 24px;
                border-radius: 22px;
            }

            .mobile-note {
                display: block;
            }
        }
    </style>
</head>
<body>
    <main class="auth-shell">
        <section class="brand-panel" aria-label="Giới thiệu hệ thống">
            <div class="brand-mark">
                <img class="brand-logo" src="~/img/ntu-logo.svg" alt="NTU" />
                <span>TRƯỜNG ĐẠI HỌC NHA TRANG<br /><small>Hệ thống quản lý coi thi</small></span>
            </div>
            <div class="hero-copy">
                <h1>Quản lý coi thi tập trung, bảo mật và rõ trách nhiệm.</h1>
                <p>Theo dõi lịch thi, phân công cán bộ coi thi và xử lý nghiệp vụ học vụ trong một hệ thống thống nhất.</p>
            </div>
        </section>

        <section class="auth-panel">
            <div class="auth-card">
                <h2>Đăng nhập</h2>
                <p class="subtitle">Sử dụng tài khoản được cấp để truy cập hệ thống.</p>

                @if (!string.IsNullOrWhiteSpace(notifyMessage))
                {
                    <div class="auth-notice @(notifyType == "success" ? "success" : "error")">@notifyMessage</div>
                }

                @using (Html.BeginForm("Login", "Account", FormMethod.Post))
                {
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="returnUrl" value="@returnUrl" />

                    @Html.ValidationSummary(false, "", new { @class = "auth-alert" })

                    <div class="form-field">
                        <label for="UserName">Tên đăng nhập</label>
                        <div class="input-wrap">
                            @Html.TextBoxFor(m => m.UserName, new { autocomplete = "username", required = "required", placeholder = "Nhập tên đăng nhập" })
                        </div>
                        @Html.ValidationMessageFor(m => m.UserName)
                    </div>

                    <div class="form-field">
                        <label for="passwordInput">Mật khẩu</label>
                        <div class="input-wrap">
                            @Html.PasswordFor(m => m.Password, new { autocomplete = "current-password", required = "required", id = "passwordInput", placeholder = "Nhập mật khẩu" })
                            <button class="toggle-password" type="button" onclick="togglePassword()">Hiện</button>
                        </div>
                        @Html.ValidationMessageFor(m => m.Password)
                    </div>

                    <div class="form-row">
                        <a href="@Url.Action("ForgotPassword", "Account")" class="link">Quên mật khẩu?</a>
                    </div>

                    <button type="submit" class="btn-login">Đăng nhập</button>
                }
            </div>
        </section>
    </main>

    <script>
        function togglePassword() {
            const input = document.getElementById("passwordInput");
            const button = document.querySelector(".toggle-password");
            const show = input.type === "password";

            input.type = show ? "text" : "password";
            button.textContent = show ? "Ẩn" : "Hiện";
        }
    </script>
</body>
</html>
