@model ExamInvigilationManagement.ViewModel.ForgotPasswordViewModel

@{
    Layout = null;
    var notifyType = TempData["Notify.Type"] as string;
    var notifyMessage = TempData["Notify.Message"] as string;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quên mật khẩu | Hệ thống quản lý coi thi</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@600;700;800;900&family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            min-height: 100vh;
            display: grid;
            place-items: center;
            padding: 24px;
            font-family: "Inter", "Segoe UI", Arial, sans-serif;
            color: #102a43;
            background:
                radial-gradient(circle at 10% 15%, rgba(14, 116, 144, 0.2), transparent 28%),
                radial-gradient(circle at 85% 8%, rgba(15, 118, 110, 0.18), transparent 24%),
                linear-gradient(135deg, #f8fafc 0%, #e0f2fe 55%, #f0fdfa 100%);
        }

        .auth-card {
            width: min(100%, 440px);
            padding: 34px;
            border-radius: 28px;
            background: #ffffff;
            box-shadow: 0 28px 90px rgba(15, 23, 42, 0.14);
        }

        .brand-logo {
            width: 92px;
            height: 92px;
            margin: 0 auto 20px;
            border-radius: 50%;
            display: block;
            object-fit: contain;
            background: #fff;
            border: 1px solid rgba(15, 118, 110, 0.16);
            box-shadow: 0 16px 32px rgba(15, 118, 110, 0.22);
        }

        h1 {
            margin: 0 0 8px;
            font-family: "Be Vietnam Pro", "Segoe UI", sans-serif;
            font-size: 28px;
            letter-spacing: -0.035em;
            color: #0f172a;
            text-align: center;
        }

        .subtitle {
            margin: 0 0 26px;
            color: #64748b;
            line-height: 1.55;
            text-align: center;
        }

        .alert {
            margin: 0 0 18px;
            padding: 13px 14px;
            border-radius: 16px;
            font-size: 14px;
            line-height: 1.5;
        }

        .alert.success {
            border: 1px solid rgba(22, 163, 74, 0.2);
            background: #f0fdf4;
            color: #166534;
        }

        .alert.error,
        .validation-summary-errors {
            border: 1px solid rgba(220, 38, 38, 0.18);
            background: #fef2f2;
            color: #991b1b;
        }

        .validation-summary-errors {
            margin: 0 0 18px;
            padding: 13px 14px;
            border-radius: 16px;
            font-size: 14px;
        }

        .form-field {
            margin-bottom: 18px;
        }

        .form-field label {
            display: block;
            margin-bottom: 8px;
            font-size: 14px;
            font-weight: 650;
            color: #334155;
        }

        .form-field input {
            width: 100%;
            height: 48px;
            padding: 0 14px;
            border: 1px solid #cbd5e1;
            border-radius: 14px;
            outline: none;
            background: #f8fafc;
            color: #0f172a;
            font-size: 15px;
            transition: border-color 0.18s ease, box-shadow 0.18s ease, background 0.18s ease;
        }

        .form-field input:focus {
            border-color: #0f766e;
            background: #fff;
            box-shadow: 0 0 0 4px rgba(15, 118, 110, 0.12);
        }

        .field-validation-error {
            display: block;
            margin-top: 6px;
            color: #b91c1c;
            font-size: 13px;
        }

        .btn-submit {
            width: 100%;
            height: 50px;
            border: 0;
            border-radius: 16px;
            color: #fff;
            cursor: pointer;
            font-size: 15px;
            font-weight: 750;
            background: linear-gradient(135deg, #0f766e, #0e7490);
            box-shadow: 0 16px 34px rgba(15, 118, 110, 0.28);
        }

        .back-link {
            display: inline-block;
            margin-top: 16px;
            color: #0f766e;
            text-decoration: none;
            font-weight: 650;
            font-size: 14px;
        }

        .back-link:hover {
            text-decoration: underline;
        }

        @@media (max-width: 520px) {
            .auth-card {
                padding: 26px;
                border-radius: 24px;
            }
        }
    </style>
</head>
<body>
    <main class="auth-card">
        <img class="brand-logo" src="~/img/ntu-logo.svg" alt="NTU" />
        <h1>Quên mật khẩu</h1>
        <p class="subtitle">Nhập tên đăng nhập và email đã đăng ký. Nếu thông tin hợp lệ, hệ thống sẽ gửi liên kết đặt lại mật khẩu.</p>

        @if (!string.IsNullOrWhiteSpace(notifyMessage))
        {
            <div class="alert @(notifyType == "success" ? "success" : "error")">@notifyMessage</div>
        }

        @using (Html.BeginForm("ForgotPassword", "Account", FormMethod.Post))
        {
            @Html.AntiForgeryToken()
            @Html.ValidationSummary(true, "", new { @class = "alert error" })

            <div class="form-field">
                <label for="Username">Tên đăng nhập</label>
                @Html.TextBoxFor(m => m.Username, new { autocomplete = "username", required = "required", placeholder = "Nhập tên đăng nhập" })
                @Html.ValidationMessageFor(m => m.Username)
            </div>

            <div class="form-field">
                <label for="Email">Email</label>
                @Html.TextBoxFor(m => m.Email, new { autocomplete = "email", required = "required", type = "email", placeholder = "Nhập email đã đăng ký" })
                @Html.ValidationMessageFor(m => m.Email)
            </div>

            <button type="submit" class="btn-submit">Gửi liên kết đặt lại</button>
            <a href="@Url.Action("Login", "Account")" class="back-link">Quay lại đăng nhập</a>
        }
    </main>
</body>
</html>
