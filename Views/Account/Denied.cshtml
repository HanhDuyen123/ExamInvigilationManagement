@{
    ViewData["Title"] = "Không có quyền truy cập";
    Layout = User.IsInRole("Admin") ? "_Layout" : "_AcademicLayout";
}

<div class="role-page">
    <div class="form-card text-center py-5">
        <div class="card-icon mx-auto mb-3">
            <i class="bi bi-shield-lock"></i>
        </div>
        <h3 class="fw-bold mb-2">Bạn không có quyền truy cập vào trang này</h3>
        <p class="text-muted mb-4">Tài khoản hiện tại không được phân quyền để mở đường dẫn đã yêu cầu.</p>
        <a asp-area="" asp-controller="Dashboard" asp-action="Index" class="btn btn-primary rounded-3 px-4">
            Quay về Dashboard
        </a>
    </div>
</div>
