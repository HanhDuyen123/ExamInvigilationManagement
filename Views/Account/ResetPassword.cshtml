@model ExamInvigilationManagement.ViewModel.ResetPasswordViewModel

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <title>Đặt lại mật khẩu</title>

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: "Segoe UI", sans-serif;
        }

        body {
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            background: url("https://img.freepik.com/free-photo/abstract-smooth-empty-grey-studio-well-use-as-background-business-report-digital-website-template-backdrop_1258-53064.jpg?w=360") no-repeat center center;
            background-size: cover;
        }

        .login-box {
            width: 380px;
            padding: 40px 30px;
            text-align: center;
            background: rgba(255, 255, 255, 0.18);
            backdrop-filter: blur(14px);
            border-radius: 20px;
        }

        .avatar {
            width: 80px;
            height: 80px;
            margin: 0 auto 20px;
            background: #0b5c6b;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
        }

            .avatar i {
                font-size: 30px;
                color: white;
            }

        .input-group {
            position: relative;
            margin: 20px 0;
        }

            .input-group input {
                width: 100%;
                padding: 12px 45px 12px 40px; /* chừa chỗ icon */
                font-size: 16px;
                border: none;
                border-bottom: 2px solid rgba(0,0,0,0.4);
                background: transparent !important;
                outline: none;
            }

            .input-group label {
                position: absolute;
                left: 40px;
                top: 12px;
                font-size: 14px;
                color: rgba(0,0,0,0.6);
                pointer-events: none;
                transition: 0.3s ease;
            }

            .input-group input:focus + label,
            .input-group input:valid + label {
                top: -8px;
                font-size: 12px;
                color: #0b5c6b;
            }

            .input-group i.left-icon {
                position: absolute;
                left: 10px;
                top: 12px;
                font-size: 18px;
                color: gray;
            }

        .toggle-password {
            position: absolute;
            right: 10px;
            top: 50%;
            transform: translateY(-50%);
            font-size: 14px;
            cursor: pointer;
            color: gray;
        }

            .toggle-password:hover {
                color: #0b5c6b;
            }

        .btn {
            width: 100%;
            border: none;
            border-radius: 8px;
            background: #0b5c6b;
            color: white;
            margin-top: 20px;
            padding: 12px;
            font-size: 15px;
        }

        .back {
            display: block;
            margin-top: 10px;
            color: black;
            text-decoration: none;
            font-size: 13px;
        }

        .text-danger {
            color: red;
            font-size: 13px;
        }

        .password-rules {
            margin-top: 12px;
            padding: 12px;
            border-radius: 12px;
            background: rgba(255,255,255,0.4);
            display: grid;
            grid-template-columns: 1fr 1fr; /* 2 cột */
            gap: 6px 12px; /* khoảng cách hàng + cột */
        }

        .rule {
            display: flex;
            align-items: center;
            font-size: 12.5px; /* nhỏ lại 1 chút */
            color: #777;
            white-space: nowrap; /* tránh xuống dòng */
        }

            .rule i {
                font-size: 10px;
                margin-right: 6px;
                color: #bbb;
                transition: 0.3s;
            }

            /* khi hợp lệ */
            .rule.valid {
                color: #0b5c6b;
            }

                .rule.valid i {
                    color: #0b5c6b;
                }

                /* animation nhẹ */
                .rule.valid span {
                    font-weight: 500;
                }

        .match-message {
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: 13px;
            margin-top: 8px;
            padding: 6px 10px;
            border-radius: 8px;
            opacity: 0;
            transform: translateY(-3px);
            transition: 0.25s ease;
        }

            /* show */
            .match-message.show {
                opacity: 1;
                transform: translateY(0);
            }

            /* SUCCESS */
            .match-message.success {
                background: rgba(11, 92, 107, 0.1);
                color: #0cb112fc;
            }

                .match-message.success i {
                    color: #0cb112fc;
                }

            /* ERROR */
            .match-message.error {
                background: rgba(231, 76, 60, 0.1);
                color: #e74c3c;
            }

                .match-message.error i {
                    color: #e74c3c;
                }
    </style>
</head>

<body>

    <div class="login-box">

        <div class="avatar">
            <i class="fa-solid fa-lock"></i>
        </div>

        @* @using (Html.BeginForm("ResetPassword", "Account", FormMethod.Post)) *@
        @using (Html.BeginForm("ResetPassword", "Account", FormMethod.Post, new { id = "resetForm" }))
        {
            @Html.AntiForgeryToken()

            @Html.HiddenFor(m => m.Token)

            @Html.ValidationSummary(true, "", new { @class = "text-danger" })
            <div class="password-rules">
                <div class="rule" id="length">
                    <i class="fa-solid fa-circle"></i>
                    <span>Ít nhất 8 ký tự</span>
                </div>
                <div class="rule" id="letter">
                    <i class="fa-solid fa-circle"></i>
                    <span>Có chữ cái</span>
                </div>
                <div class="rule" id="number">
                    <i class="fa-solid fa-circle"></i>
                    <span>Có số</span>
                </div>
                <div class="rule" id="special">
                    <i class="fa-solid fa-circle"></i>
                    <span>Ký tự đặc biệt</span>
                </div>
            </div>

            <div id="matchMessage" class="match-message">
                <i class="fa-solid"></i>
                <span></span>
            </div>

            <!-- NEW PASSWORD -->
            <div class="input-group">
                <i class="fa-solid fa-lock left-icon"></i>

                @Html.PasswordFor(m => m.NewPassword, new
                    {
                        required = "required",
                        id = "newPassword"
                    })

                <label>Mật khẩu mới</label>

                <i class="fa-solid fa-eye toggle-password" onclick="togglePassword('newPassword', this)"></i>
            </div>

            <!-- CONFIRM PASSWORD -->
            <div class="input-group">
                <i class="fa-solid fa-lock left-icon"></i>

                @Html.PasswordFor(m => m.ConfirmPassword, new
                    {
                        required = "required",
                        id = "confirmPassword"
                    })

                <label>Xác nhận mật khẩu</label>

                <i class="fa-solid fa-eye toggle-password" onclick="togglePassword('confirmPassword', this)"></i>
            </div>

            <button type="submit" class="btn">Đặt lại mật khẩu</button>

            <a href="@Url.Action("Login", "Account")" class="back">
                ← Quay lại đăng nhập
            </a>
        }

    </div>

    <script>
        const password = document.getElementById("newPassword");
        const confirmPassword = document.getElementById("confirmPassword");
        const form = document.getElementById("resetForm");
        const submitBtn = document.querySelector(".btn");

        const length = document.getElementById("length");
        const letter = document.getElementById("letter");
        const number = document.getElementById("number");
        const special = document.getElementById("special");
        const matchMessage = document.getElementById("matchMessage");

        // ========================
        // PASSWORD INPUT
        // ========================
        password.addEventListener("input", function () {
            const value = password.value;

            const hasLength = value.length >= 8;
            const hasLetter = /[A-Za-z]/.test(value);
            const hasNumber = /[0-9]/.test(value);
            const hasSpecial = /[^A-Za-z0-9]/.test(value);

            updateUI(length, hasLength);
            updateUI(letter, hasLetter);
            updateUI(number, hasNumber);
            updateUI(special, hasSpecial);

            if (hasLength && hasLetter && hasNumber && hasSpecial) {
                password.classList.add("valid-input");
                password.classList.remove("invalid-input");
            } else {
                password.classList.add("invalid-input");
                password.classList.remove("valid-input");
            }

            checkMatch();
            toggleSubmit();
        });

        // ========================
        // CONFIRM INPUT
        // ========================
        confirmPassword.addEventListener("input", function () {
            checkMatch();
            toggleSubmit();
        });

        // ========================
        // CHECK MATCH
        // ========================
        function checkMatch() {
            const icon = matchMessage.querySelector("i");
            const text = matchMessage.querySelector("span");

            if (confirmPassword.value === "") {
                matchMessage.className = "match-message";
                text.innerText = "";
                return false;
            }

            matchMessage.classList.add("show");

            if (confirmPassword.value === password.value) {
                matchMessage.className = "match-message success show";
                icon.className = "fa-solid fa-check-circle";
                text.innerText = "Mật khẩu khớp";
                return true;
            } else {
                matchMessage.className = "match-message error show";
                icon.className = "fa-solid fa-circle-xmark";
                text.innerText = "Mật khẩu không khớp";
                return false;
            }
        }

        // ========================
        // UPDATE RULE UI
        // ========================
        function updateUI(element, isValid) {
            const icon = element.querySelector("i");

            if (isValid) {
                element.classList.add("valid");
                icon.classList.remove("fa-circle");
                icon.classList.add("fa-check");
            } else {
                element.classList.remove("valid");
                icon.classList.remove("fa-check");
                icon.classList.add("fa-circle");
            }
        }

        // ========================
        // TOGGLE PASSWORD
        // ========================
        function togglePassword(inputId, icon) {
            var input = document.getElementById(inputId);

            input.focus();

            if (input.type === "password") {
                input.type = "text";
                icon.classList.remove("fa-eye");
                icon.classList.add("fa-eye-slash");
            } else {
                input.type = "password";
                icon.classList.remove("fa-eye-slash");
                icon.classList.add("fa-eye");
            }
        }

        // ========================
        // CHECK PASSWORD STRONG
        // ========================
        function isStrongPassword() {
            const value = password.value;
            return (
                value.length >= 8 &&
                /[A-Za-z]/.test(value) &&
                /[0-9]/.test(value) &&
                /[^A-Za-z0-9]/.test(value)
            );
        }

        // ========================
        // ENABLE/DISABLE BUTTON
        // ========================
        function toggleSubmit() {
            const valid = isStrongPassword() && password.value === confirmPassword.value;

            submitBtn.disabled = !valid;
            submitBtn.style.opacity = valid ? "1" : "0.6";
        }

        // ========================
        // SUBMIT FORM
        // ========================
        form.addEventListener("submit", function (e) {

            const icon = matchMessage.querySelector("i");
            const text = matchMessage.querySelector("span");

            // ❌ Password yếu
            if (!isStrongPassword()) {
                e.preventDefault();

                matchMessage.className = "match-message error show";
                icon.className = "fa-solid fa-circle-exclamation";
                text.innerText = "Mật khẩu chưa đủ mạnh";

                password.focus();
                return;
            }

            // ❌ Confirm sai
            if (password.value !== confirmPassword.value) {
                e.preventDefault();

                matchMessage.className = "match-message error show";
                icon.className = "fa-solid fa-circle-xmark";
                text.innerText = "Xác nhận mật khẩu không khớp";

                // 🔥 clear confirm
                confirmPassword.value = "";
                confirmPassword.classList.remove("valid-input");

                confirmPassword.focus();
                return;
            }

            // ✅ OK → submit
        });

        // init trạng thái button
        toggleSubmit();
    </script>

</body>
</html>