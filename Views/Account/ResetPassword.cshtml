@model ExamInvigilationManagement.ViewModel.ResetPasswordViewModel

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Đặt lại mật khẩu | Hệ thống quản lý coi thi</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@600;700;800;900&family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        * { box-sizing: border-box; }

        body {
            margin: 0;
            min-height: 100vh;
            display: grid;
            place-items: center;
            padding: 24px;
            font-family: "Inter", "Segoe UI", Arial, sans-serif;
            color: #102a43;
            background:
                radial-gradient(circle at 10% 15%, rgba(14, 116, 144, 0.2), transparent 28%),
                radial-gradient(circle at 85% 8%, rgba(15, 118, 110, 0.18), transparent 24%),
                linear-gradient(135deg, #f8fafc 0%, #e0f2fe 55%, #f0fdfa 100%);
        }

        .auth-card {
            width: min(100%, 460px);
            padding: 34px;
            border-radius: 28px;
            background: #fff;
            box-shadow: 0 28px 90px rgba(15, 23, 42, 0.14);
        }

        .brand-logo {
            width: 92px;
            height: 92px;
            margin: 0 auto 20px;
            border-radius: 50%;
            display: block;
            object-fit: contain;
            background: #fff;
            border: 1px solid rgba(15, 118, 110, 0.16);
            box-shadow: 0 16px 32px rgba(15, 118, 110, 0.22);
        }

        h1 {
            margin: 0 0 8px;
            font-family: "Be Vietnam Pro", "Segoe UI", sans-serif;
            font-size: 28px;
            letter-spacing: -0.035em;
            color: #0f172a;
            text-align: center;
        }

        .subtitle {
            margin: 0 0 22px;
            color: #64748b;
            line-height: 1.55;
            text-align: center;
        }

        .validation-summary-errors {
            margin: 0 0 18px;
            padding: 13px 14px;
            border-radius: 16px;
            border: 1px solid rgba(220, 38, 38, 0.18);
            background: #fef2f2;
            color: #991b1b;
            font-size: 14px;
            line-height: 1.5;
        }

        .validation-summary-errors ul { margin: 0; padding-left: 18px; }

        .password-rules {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 8px 12px;
            margin: 0 0 18px;
            padding: 14px;
            border-radius: 16px;
            background: #f8fafc;
            border: 1px solid #e2e8f0;
        }

        .rule {
            display: flex;
            align-items: center;
            gap: 8px;
            color: #64748b;
            font-size: 13px;
        }

        .rule::before {
            content: "";
            width: 8px;
            height: 8px;
            border-radius: 999px;
            background: #cbd5e1;
        }

        .rule.valid { color: #0f766e; font-weight: 650; }
        .rule.valid::before { background: #0f766e; }

        .form-field { margin-bottom: 18px; }

        .form-field label {
            display: block;
            margin-bottom: 8px;
            font-size: 14px;
            font-weight: 650;
            color: #334155;
        }

        .input-wrap { position: relative; }

        .input-wrap input {
            width: 100%;
            height: 48px;
            padding: 0 60px 0 14px;
            border: 1px solid #cbd5e1;
            border-radius: 14px;
            outline: none;
            background: #f8fafc;
            color: #0f172a;
            font-size: 15px;
            transition: border-color 0.18s ease, box-shadow 0.18s ease, background 0.18s ease;
        }

        .input-wrap input:focus {
            border-color: #0f766e;
            background: #fff;
            box-shadow: 0 0 0 4px rgba(15, 118, 110, 0.12);
        }

        .toggle-password {
            position: absolute;
            right: 10px;
            top: 50%;
            transform: translateY(-50%);
            border: 0;
            background: transparent;
            color: #0f766e;
            cursor: pointer;
            font-weight: 650;
        }

        .field-validation-error {
            display: block;
            margin-top: 6px;
            color: #b91c1c;
            font-size: 13px;
        }

        .match-message {
            display: none;
            margin: -4px 0 16px;
            padding: 10px 12px;
            border-radius: 14px;
            font-size: 14px;
        }

        .match-message.show { display: block; }
        .match-message.success { background: #f0fdf4; color: #166534; border: 1px solid rgba(22, 163, 74, 0.2); }
        .match-message.error { background: #fef2f2; color: #991b1b; border: 1px solid rgba(220, 38, 38, 0.18); }

        .btn-submit {
            width: 100%;
            height: 50px;
            border: 0;
            border-radius: 16px;
            color: #fff;
            cursor: pointer;
            font-size: 15px;
            font-weight: 750;
            background: linear-gradient(135deg, #0f766e, #0e7490);
            box-shadow: 0 16px 34px rgba(15, 118, 110, 0.28);
        }

        .btn-submit:disabled { cursor: not-allowed; opacity: .6; }

        .back-link {
            display: inline-block;
            margin-top: 16px;
            color: #0f766e;
            text-decoration: none;
            font-weight: 650;
            font-size: 14px;
        }

        .back-link:hover { text-decoration: underline; }

        @@media (max-width: 520px) {
            .auth-card { padding: 26px; border-radius: 24px; }
            .password-rules { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body>
    <main class="auth-card">
        <img class="brand-logo" src="~/img/ntu-logo.svg" alt="NTU" />
        <h1>Đặt lại mật khẩu</h1>
        <p class="subtitle">Tạo mật khẩu mới đủ mạnh để bảo vệ tài khoản của bạn.</p>

        @using (Html.BeginForm("ResetPassword", "Account", FormMethod.Post, new { id = "resetForm" }))
        {
            @Html.AntiForgeryToken()
            @Html.HiddenFor(m => m.Token)
            @Html.ValidationSummary(true, "", new { @class = "validation-summary-errors" })

            <div class="password-rules">
                <div class="rule" id="length">Ít nhất 8 ký tự</div>
                <div class="rule" id="letter">Có chữ cái</div>
                <div class="rule" id="number">Có số</div>
                <div class="rule" id="special">Ký tự đặc biệt</div>
            </div>

            <div class="form-field">
                <label for="newPassword">Mật khẩu mới</label>
                <div class="input-wrap">
                    @Html.PasswordFor(m => m.NewPassword, new { required = "required", id = "newPassword", autocomplete = "new-password", placeholder = "Nhập mật khẩu mới" })
                    <button class="toggle-password" type="button" onclick="togglePassword('newPassword', this)">Hiện</button>
                </div>
                @Html.ValidationMessageFor(m => m.NewPassword)
            </div>

            <div class="form-field">
                <label for="confirmPassword">Xác nhận mật khẩu</label>
                <div class="input-wrap">
                    @Html.PasswordFor(m => m.ConfirmPassword, new { required = "required", id = "confirmPassword", autocomplete = "new-password", placeholder = "Nhập lại mật khẩu mới", onpaste = "return false", ondrop = "return false", oncopy = "return false", oncut = "return false" })
                    <button class="toggle-password" type="button" onclick="togglePassword('confirmPassword', this)">Hiện</button>
                </div>
                @Html.ValidationMessageFor(m => m.ConfirmPassword)
            </div>

            <div id="matchMessage" class="match-message"></div>

            <button type="submit" class="btn-submit">Đặt lại mật khẩu</button>
            <a href="@Url.Action("Login", "Account")" class="back-link">Quay lại đăng nhập</a>
        }
    </main>

    <script>
        const password = document.getElementById("newPassword");
        const confirmPassword = document.getElementById("confirmPassword");
        const form = document.getElementById("resetForm");
        const submitBtn = document.querySelector(".btn-submit");
        const matchMessage = document.getElementById("matchMessage");
        const rules = {
            length: document.getElementById("length"),
            letter: document.getElementById("letter"),
            number: document.getElementById("number"),
            special: document.getElementById("special")
        };

        confirmPassword.addEventListener("paste", preventConfirmTransfer);
        confirmPassword.addEventListener("drop", preventConfirmTransfer);
        password.addEventListener("input", updateState);
        confirmPassword.addEventListener("input", updateState);

        function preventConfirmTransfer(event) {
            event.preventDefault();
            showMessage("error", "Vui lòng nhập lại mật khẩu xác nhận, không dán/copy từ ô mật khẩu mới.");
        }

        function togglePassword(inputId, button) {
            const input = document.getElementById(inputId);
            const show = input.type === "password";
            input.type = show ? "text" : "password";
            button.textContent = show ? "Ẩn" : "Hiện";
        }

        function isStrongPassword() {
            const value = password.value;
            const checks = {
                length: value.length >= 8,
                letter: /[A-Za-z]/.test(value),
                number: /[0-9]/.test(value),
                special: /[^A-Za-z0-9]/.test(value)
            };

            Object.entries(checks).forEach(([key, valid]) => {
                rules[key].classList.toggle("valid", valid);
            });

            return Object.values(checks).every(Boolean);
        }

        function updateState() {
            const strong = isStrongPassword();
            const matches = confirmPassword.value !== "" && password.value === confirmPassword.value;

            if (confirmPassword.value === "") {
                matchMessage.className = "match-message";
                matchMessage.textContent = "";
            } else if (matches) {
                showMessage("success", "Mật khẩu xác nhận khớp.");
            } else {
                showMessage("error", "Mật khẩu xác nhận không khớp.");
            }

            submitBtn.disabled = !(strong && matches);
        }

        function showMessage(type, text) {
            matchMessage.className = `match-message ${type} show`;
            matchMessage.textContent = text;
        }

        form.addEventListener("submit", function (event) {
            if (!isStrongPassword()) {
                event.preventDefault();
                showMessage("error", "Mật khẩu phải có ít nhất 8 ký tự, gồm chữ cái, số và ký tự đặc biệt.");
                password.focus();
                return;
            }

            if (password.value !== confirmPassword.value) {
                event.preventDefault();
                showMessage("error", "Mật khẩu xác nhận không khớp.");
                confirmPassword.value = "";
                confirmPassword.focus();
            }
        });

        updateState();
    </script>
</body>
</html>
