@* Views/Notification/_NotificationDropdownItems.cshtml *@
@model IEnumerable<ExamInvigilationManagement.Application.DTOs.Notification.NotificationListItemDto>
@using ExamInvigilationManagement.Common.Helpers

@if (Model != null && Model.Any())
{
    foreach (var item in Model)
    {
        <a href="@Url.Action("Open", "Notification", new { id = item.Id })"
           class="dropdown-item notification-item @(item.IsRead ? "" : "unread")"
           data-id="@item.Id">
            <div class="d-flex justify-content-between align-items-start gap-2">
                <div class="me-2">
                    <div class="fw-semibold">
                        <i class="bi @NotificationTypeHelper.GetIcon(item.Type)"></i>
                        @item.Title
                    </div>
                    <div class="small text-muted text-truncate" style="max-width: 300px;">
                        @item.Content
                    </div>
                </div>
                <div class="small text-muted text-nowrap">
                    @item.CreatedAt.ToString("dd/MM HH:mm")
                </div>
            </div>
        </a>
    }
}
else
{
    <div class="p-3 text-muted">Chưa có thông báo</div>
}
