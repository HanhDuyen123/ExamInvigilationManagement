@using ExamInvigilationManagement.Application.DTOs
@model ProfileDto

@{
    ViewData["Title"] = "Thông tin cá nhân";
    var fullName = $"{Model.LastName} {Model.FirstName}".Trim();
    var avatarText = !string.IsNullOrWhiteSpace(Model.LastName)
        ? Model.LastName.Substring(0, 1).ToUpper()
        : "U";
}

<div class="profile-page role-page">
    <div class="profile-summary-card">
        <div class="profile-avatar">
            @if (!string.IsNullOrWhiteSpace(Model.Avt))
            {
                <img src="@Model.Avt" alt="Ảnh đại diện" />
            }
            else
            {
                <span>@avatarText</span>
            }
        </div>

        <div class="profile-summary-main">
            <div class="profile-kicker">Hồ sơ tài khoản</div>
            <h3>@(string.IsNullOrWhiteSpace(fullName) ? Model.UserName : fullName)</h3>
            <div class="profile-meta">
                <span><i class="bi bi-person"></i>@Model.UserName</span>
                <span><i class="bi bi-envelope"></i>@Model.Email</span>
                @if (!string.IsNullOrWhiteSpace(Model.PositionName))
                {
                    <span><i class="bi bi-briefcase"></i>@Model.PositionName</span>
                }
            </div>
        </div>

        <span class="badge rounded-pill px-3 py-2 @(Model.IsActive ? "bg-success" : "bg-danger")">
            @(Model.IsActive ? "Đang hoạt động" : "Đã khóa")
        </span>
    </div>

    <form asp-area="" asp-controller="Profile" asp-action="Update" method="post" enctype="multipart/form-data" class="profile-edit-card">
        @Html.AntiForgeryToken()
        <div class="profile-form-grid">
            <div class="form-group profile-avatar-upload">
                <label class="form-label">Ảnh đại diện</label>
                <div class="avatar-upload-row">
                    <div class="profile-avatar small-preview" id="avatarPreview">
                        @if (!string.IsNullOrWhiteSpace(Model.Avt))
                        {
                            <img src="@Model.Avt" alt="Ảnh đại diện hiện tại" />
                        }
                        else
                        {
                            <span>@avatarText</span>
                        }
                    </div>
                    <div class="flex-grow-1">
                        <input type="file" class="form-control" name="avatarFile" id="avatarFile" accept="image/png,image/jpeg,image/webp" />
                        <div class="form-text">JPG, PNG hoặc WEBP, tối đa 2MB.</div>
                    </div>
                </div>
            </div>

            <div class="form-group">
                <label class="form-label">Tên đăng nhập</label>
                <input class="input-modern" value="@Model.UserName" disabled />
            </div>

            <div class="form-group">
                <label class="form-label">Email</label>
                <input class="input-modern" value="@Model.Email" disabled />
            </div>

            <div class="form-group">
                <label class="form-label">Họ</label>
                <input class="input-modern" name="LastName" value="@Model.LastName" />
            </div>

            <div class="form-group">
                <label class="form-label">Tên</label>
                <input class="input-modern" name="FirstName" value="@Model.FirstName" />
            </div>

            <div class="form-group">
                <label class="form-label">Số điện thoại</label>
                <input class="input-modern" name="Phone" value="@Model.Phone" />
            </div>

            <div class="form-group">
                <label class="form-label">Giới tính</label>
                <div class="radio-card-group">
                    <label class="radio-card">
                        <input type="radio" name="Gender" value="Male" checked="@(string.Equals(Model.Gender, "Male", StringComparison.OrdinalIgnoreCase))" />
                        <span>Nam</span>
                    </label>
                    <label class="radio-card">
                        <input type="radio" name="Gender" value="Female" checked="@(string.Equals(Model.Gender, "Female", StringComparison.OrdinalIgnoreCase))" />
                        <span>Nữ</span>
                    </label>
                </div>
            </div>

            <div class="form-group">
                <label class="form-label">Ngày sinh</label>
                <input type="date" class="input-modern" name="Dob" value="@(Model.Dob?.ToString("yyyy-MM-dd"))" />
            </div>

            <div class="form-group">
                <label class="form-label">Chức vụ</label>
                <input class="input-modern" value="@Model.PositionName" disabled />
            </div>

            <div class="form-group profile-address-field">
                <label class="form-label">Địa chỉ</label>
                <input class="input-modern" name="Address" value="@Model.Address" />
            </div>
        </div>

        <div class="profile-actions">
            <button class="btn-submit" type="submit">
                <i class="bi bi-save"></i> Lưu thay đổi
            </button>
            <button type="reset" class="btn btn-outline-secondary rounded-3 px-4">
                Làm lại
            </button>
        </div>
    </form>
</div>

<style>
    .profile-page {
        display: grid;
        gap: 16px;
    }

    .profile-summary-card,
    .profile-edit-card {
        border: 1px solid var(--line-soft);
        border-radius: 22px;
        background: var(--surface-1);
        box-shadow: var(--card-shadow);
    }

    .profile-summary-card {
        display: grid;
        grid-template-columns: auto minmax(0, 1fr) auto;
        align-items: center;
        gap: 16px;
        padding: 20px;
    }

    .profile-avatar {
        width: 64px;
        height: 64px;
        border-radius: 20px;
        display: grid;
        place-items: center;
        overflow: hidden;
        color: #fff;
        font-size: 24px;
        font-weight: 900;
        background: linear-gradient(135deg, var(--app-primary), var(--app-primary-2));
    }

    .profile-avatar img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .profile-kicker {
        color: var(--app-primary);
        font-weight: 800;
        font-size: 12px;
        text-transform: uppercase;
        letter-spacing: .08em;
    }

    .profile-summary-main h3 {
        margin: 2px 0 8px;
        font-weight: 850;
    }

    .profile-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 8px 14px;
        color: var(--text-muted);
        font-size: 13px;
    }

    .profile-meta span {
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }

    .profile-edit-card {
        padding: 22px;
    }

    .profile-form-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 14px;
    }

    .profile-address-field {
        grid-column: span 2;
    }

    .profile-avatar-upload {
        grid-column: 1 / -1;
    }

    .avatar-upload-row {
        display: flex;
        align-items: center;
        gap: 14px;
        padding: 12px;
        border: 1px solid var(--line-soft);
        border-radius: 16px;
        background: var(--surface-3);
    }

    .profile-avatar.small-preview {
        width: 58px;
        height: 58px;
        border-radius: 18px;
        font-size: 22px;
        flex: 0 0 auto;
    }

    .radio-card-group {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 10px;
    }

    .radio-card {
        display: flex;
        align-items: center;
        gap: 8px;
        min-height: 38px;
        padding: 8px 11px;
        border: 1px solid var(--line-medium);
        border-radius: 12px;
        color: var(--text-main);
        background: var(--surface-2);
        font-weight: 750;
    }

    .radio-card input { accent-color: var(--app-primary); }

    .profile-actions {
        display: flex;
        justify-content: flex-end;
        gap: 10px;
        margin-top: 18px;
    }

    @@media (max-width: 1100px) {
        .profile-form-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    }

    @@media (max-width: 640px) {
        .profile-summary-card { grid-template-columns: 1fr; }
        .profile-form-grid { grid-template-columns: 1fr; }
        .profile-address-field { grid-column: auto; }
        .profile-actions { justify-content: stretch; flex-direction: column; }
    }
</style>

<script>
    document.getElementById('avatarFile')?.addEventListener('change', function () {
        const file = this.files && this.files[0];
        if (!file || !file.type.startsWith('image/')) return;
        const preview = document.getElementById('avatarPreview');
        if (!preview) return;
        const url = URL.createObjectURL(file);
        preview.innerHTML = '<img src="' + url + '" alt="Ảnh đại diện xem trước" />';
    });
</script>
