@model ExamInvigilationManagement.ViewModel.ChangePasswordViewModel

@{
    ViewData["Title"] = "Đổi mật khẩu";
}

<div class="pw-wrapper role-page">

    <div class="pw-header">
        <div class="icon">
            <i class="bi bi-shield-lock-fill"></i>
        </div>
        <div>
            <h4>Đổi mật khẩu</h4>
            <p>Cập nhật mật khẩu định kỳ để bảo vệ tài khoản</p>
        </div>
    </div>

    <div class="pw-card">

        <form asp-action="ChangePassword" method="post">
            <div asp-validation-summary="All" class="text-danger"></div>

            <div class="pw-content-grid">
                <div class="pw-input-block">

                <div class="pw-input">
                    <label>Mật khẩu hiện tại</label>
                    <input type="password" id="currentPassword" name="CurrentPassword"
                           placeholder="Mật khẩu hiện tại" />
                    <i class="bi bi-eye toggle-eye" data-target="currentPassword"></i>
                </div>

                <div class="pw-input">
                    <label>Mật khẩu mới</label>
                    <input type="password" id="newPassword" name="NewPassword"
                           placeholder="Mật khẩu mới" />
                    <i class="bi bi-eye toggle-eye" data-target="newPassword"></i>
                </div>

                <div class="pw-input">
                    <label>Xác nhận mật khẩu mới</label>
                    <input type="password" id="confirmPassword" name="ConfirmPassword"
                           placeholder="Xác nhận mật khẩu mới" />
                    <i class="bi bi-eye toggle-eye" data-target="confirmPassword"></i>
                </div>

                </div>

                <div>
                <div id="msgBox" class="pw-message"></div>

                <div class="security-meter">

                <div class="meter-label">
                    Độ mạnh mật khẩu
                    <span id="strengthText">Yếu</span>
                </div>

                <div class="meter-bar">
                    <div id="bar"></div>
                </div>

                <div class="nodes">
                    <div id="n1"></div>
                    <div id="n2"></div>
                    <div id="n3"></div>
                    <div id="n4"></div>
                    <div id="n5"></div>
                </div>

                <div class="pw-rules-grid">
                    <div class="rule" id="r1">✔ 8+ ký tự</div>
                    <div class="rule" id="r2">✔ chữ thường</div>
                    <div class="rule" id="r3">✔ chữ hoa</div>
                    <div class="rule" id="r4">✔ số</div>
                    <div class="rule" id="r5">✔ ký tự đặc biệt</div>
                </div>

                </div>
                </div>
            </div>

            <button id="submitBtn" class="pw-submit-btn" type="submit" disabled>
                Cập nhật mật khẩu
            </button>

        </form>

    </div>
</div>

<style>
    .pw-wrapper {
        max-width: 980px;
        margin: auto;
        padding: 4px 0 24px;
    }

    .pw-header {
        display: flex;
        gap: 14px;
        align-items: center;
        padding: 20px 22px;
        border-radius: 20px;
        background: linear-gradient(135deg,var(--app-primary),var(--app-primary-2));
        color: white;
        box-shadow: var(--card-shadow);
    }

    .pw-header h4 { margin: 0 0 4px; font-weight: 850; color: #fff; }
    .pw-header p { margin: 0; opacity: .88; }
    .pw-header .icon { width: 46px; height: 46px; border-radius: 15px; display: grid; place-items: center; background: rgba(255,255,255,.18); }

    .pw-card {
        margin-top: 20px;
        background: var(--surface-1);
        border: 1px solid var(--line-soft);
        padding: 20px;
        border-radius: 22px;
        box-shadow: var(--card-shadow);
    }

    .pw-content-grid {
        display: grid;
        grid-template-columns: minmax(0, 1fr) minmax(300px, .85fr);
        gap: 18px;
        align-items: start;
    }

    .pw-input {
        position: relative;
        margin-bottom: 12px;
    }

        .pw-input label {
            display: block;
            margin-bottom: 6px;
            color: var(--text-muted);
            font-size: 13px;
            font-weight: 800;
        }

        .pw-input input {
            width: 100%;
            height: 42px;
            padding: 10px 42px 10px 14px;
            border-radius: 12px;
            border: 1px solid var(--line-soft);
            background: var(--surface-2);
            color: var(--text-main);
        }

            .pw-input input:focus { outline: none; border-color: var(--app-primary); box-shadow: 0 0 0 3px var(--focus-ring); }

    .toggle-eye {
        position: absolute;
        right: 14px;
        bottom: 12px;
        cursor: pointer;
        color: #94a3b8;
    }

    .security-meter {
        margin-top: 0;
        padding: 16px;
        border-radius: 16px;
        background: var(--surface-3);
        border: 1px solid var(--line-soft);
    }

    .meter-label {
        display: flex;
        justify-content: space-between;
        font-size: 14px;
        margin-bottom: 8px;
        color: var(--text-main);
        font-weight: 800;
    }

        .meter-label span { color: var(--app-primary); }

    .meter-bar {
        height: 8px;
        background: var(--surface-4);
        border-radius: 999px;
        overflow: hidden;
    }

        .meter-bar div {
            height: 100%;
            width: 0%;
            background: linear-gradient(90deg,#ef4444,#f59e0b,#22c55e);
            transition: 0.3s ease;
        }

    .nodes {
        display: flex;
        justify-content: space-between;
        margin-top: 12px;
    }

        .nodes div {
            width: 14px;
            height: 14px;
            border-radius: 50%;
            background: var(--surface-4);
        }

    .pw-rules-grid {
        margin-top: 14px;
        display: grid;
        grid-template-columns: repeat(auto-fit,minmax(110px,1fr));
        gap: 8px;
    }

    .rule {
        font-size: 12px;
        padding: 8px;
        text-align: center;
        border-radius: 10px;
        background: var(--surface-2);
        color: var(--text-muted);
    }

        .rule.ok {
            background: rgba(34, 197, 94, .16);
            color: #16a34a;
            font-weight: 600;
        }

    .pw-message {
        min-height: 22px;
        margin-bottom: 10px;
        font-size: 13px;
        color: #ef4444;
    }

    .pw-submit-btn {
        margin-top: 20px;
        width: 100%;
        padding: 12px 14px;
        border-radius: 14px;
        border: none;
        background: #94a3b8;
        color: white;
        font-weight: 600;
        cursor: not-allowed;
    }

        .pw-submit-btn.active {
            background: linear-gradient(135deg,var(--app-primary),var(--app-primary-2));
            cursor: pointer;
            box-shadow: 0 14px 28px rgba(37, 99, 235, .22);
        }

    @@media (max-width: 900px) {
        .pw-content-grid { grid-template-columns: 1fr; }
    }

    .modal-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.4);
        display: none;
        justify-content: center;
        align-items: center;
        z-index: 9999;
    }

    .modal-box {
        background: var(--surface-1);
        color: var(--text-main);
        padding: 30px;
        border-radius: 18px;
        text-align: center;
        width: 320px;
        animation: pop 0.25s ease;
    }

        .modal-box .icon {
            font-size: 40px;
            color: #22c55e;
            margin-bottom: 10px;
        }

    .countdown {
        margin-top: 10px;
        font-weight: bold;
        color: #3b82f6;
    }

    @@keyframes pop {
        from

    {
        transform: scale(0.8);
        opacity: 0;
    }

    to {
        transform: scale(1);
        opacity: 1;
    }

    }
</style>

<script>
    const newPw = document.getElementById("newPassword");
    const confirmPw = document.getElementById("confirmPassword");
    const currentPw = document.getElementById("currentPassword");
    const btn = document.getElementById("submitBtn");
    const msg = document.getElementById("msgBox");

    const bar = document.getElementById("bar");
    const text = document.getElementById("strengthText");

    const rules = [
        document.getElementById("r1"),
        document.getElementById("r2"),
        document.getElementById("r3"),
        document.getElementById("r4"),
        document.getElementById("r5")
    ];

    // ================= PASSWORD VALIDATION =================
    function validate() {

        const v = newPw.value || "";
        const c = confirmPw.value || "";
        const cur = currentPw.value || "";

        const hasLength = v.length >= 8;
        const hasLower = /[a-z]/.test(v);
        const hasUpper = /[A-Z]/.test(v);
        const hasNumber = /[0-9]/.test(v);
        const hasSpecial = /[^A-Za-z0-9]/.test(v);

        const score = [hasLength, hasLower, hasUpper, hasNumber, hasSpecial]
            .filter(Boolean).length;

        // strength bar
        bar.style.width = (score / 5) * 100 + "%";

        if (score <= 2) text.innerText = "Yếu";
        else if (score === 3) text.innerText = "Trung bình";
        else if (score === 4) text.innerText = "Tốt";
        else text.innerText = "Mạnh";

        // rules UI
        rules[0].classList.toggle("ok", hasLength);
        rules[1].classList.toggle("ok", hasLower);
        rules[2].classList.toggle("ok", hasUpper);
        rules[3].classList.toggle("ok", hasNumber);
        rules[4].classList.toggle("ok", hasSpecial);

        // message logic
        msg.innerHTML = "";

        if (v && cur && v === cur) {
            msg.innerHTML = "❌ Mật khẩu mới không được trùng mật khẩu hiện tại";
        }
        else if (v && c && v !== c) {
            msg.innerHTML = "❌ Mật khẩu xác nhận không khớp";
        }
        else if (v && score < 5) {
            msg.innerHTML = "❌ Mật khẩu chưa đủ mạnh";
        }

        // button enable
        const ok =
            score === 5 &&
            v === c &&
            v !== "" &&
            v !== cur;

        btn.disabled = !ok;
        btn.classList.toggle("active", ok);
    }

    // ================= EYE TOGGLE =================
    document.querySelectorAll(".toggle-eye").forEach(i => {
        i.addEventListener("click", () => {
            const input = document.getElementById(i.dataset.target);
            input.type = input.type === "password" ? "text" : "password";
            i.classList.toggle("bi-eye");
            i.classList.toggle("bi-eye-slash");
        });
    });

    // ================= EVENT =================
    newPw.addEventListener("input", validate);
    confirmPw.addEventListener("input", validate);
    currentPw.addEventListener("input", validate);

    validate();

</script>
