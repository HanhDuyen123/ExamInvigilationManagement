@using ExamInvigilationManagement.Common
@model IPagedResult

<nav class="mt-3" aria-label="Phân trang">
    <ul class="pagination">
        @if (Model.Page > 1)
        {
            <li class="page-item"><a class="page-link" href="#" data-page="1" title="Trang đầu">«</a></li>
            <li class="page-item"><a class="page-link" href="#" data-page="@(Model.Page - 1)" title="Trang trước">‹</a></li>
        }

        @for (int i = 1; i <= Model.TotalPages; i++)
        {
            <li class="page-item @(i == Model.Page ? "active" : "")">
                <a class="page-link" href="#" data-page="@i">@i</a>
            </li>
        }

        @if (Model.Page < Model.TotalPages)
        {
            <li class="page-item"><a class="page-link" href="#" data-page="@(Model.Page + 1)" title="Trang sau">›</a></li>
            <li class="page-item"><a class="page-link" href="#" data-page="@Model.TotalPages" title="Trang cuối">»</a></li>
        }
    </ul>
</nav>
