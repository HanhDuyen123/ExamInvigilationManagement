@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@inject ExamInvigilationManagement.Application.Interfaces.Service.IUserService CurrentUserService
@{
    var antiforgeryToken = Antiforgery.GetAndStoreTokens(Context).RequestToken;

    var controller = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var roleName = User.IsInRole("Trưởng khoa") ? "Trưởng khoa"
        : User.IsInRole("Thư ký khoa") ? "Thư ký khoa"
        : "Giảng viên";

    bool IsActive(string c) => string.Equals(controller, c, StringComparison.OrdinalIgnoreCase);

    // Dashboard: ẩn sidebar + toggle
    bool isDashboardPage = string.Equals(controller, "Dashboard", StringComparison.OrdinalIgnoreCase);
    bool showSidebar = !isDashboardPage;
    var currentUserIdRaw = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
    var currentProfile = int.TryParse(currentUserIdRaw, out var currentUserId) ? await CurrentUserService.GetProfileAsync(currentUserId) : null;
    var currentName = $"{currentProfile?.LastName} {currentProfile?.FirstName}".Trim();
    var currentInitial = !string.IsNullOrWhiteSpace(currentName) ? currentName.Substring(0, 1).ToUpperInvariant() : "U";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="request-verification-token" content="@antiforgeryToken" />
    <title>@ViewData["Title"] - ExamInvigilationManagement</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@600;700;800;900&family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <script>
        (function () {
            var key = 'exam-ui-theme';
            var theme = localStorage.getItem(key) || (window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
            document.documentElement.setAttribute('data-theme', theme);
        })();
    </script>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">

    <link rel="stylesheet" href="~/css/app_shell.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin_index.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin_create_edit.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/notification.css" asp-append-version="true" />

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <style>
        :root {
            --primary: #4f46e5;
            --primary-2: #6366f1;
            --text: #1e293b;
            --muted: #64748b;
            --border: rgba(79, 70, 229, 0.12);
            --shadow: 0 18px 48px rgba(15, 23, 42, 0.08);
            --shadow-hover: 0 22px 60px rgba(79, 70, 229, 0.16);
        }

        * {
            box-sizing: border-box;
        }

        body.app-shell-body {
            margin: 0;
            font-family: "Inter", "Segoe UI", system-ui, -apple-system, BlinkMacSystemFont, sans-serif;
            color: var(--text);
            background: radial-gradient(circle at top left, rgba(99, 102, 241, 0.16), transparent 28%), radial-gradient(circle at top right, rgba(14, 165, 233, 0.12), transparent 22%), linear-gradient(135deg, #eef2ff 0%, #f8fafc 46%, #ffffff 100%);
        }

        .app-topbar {
            position: sticky;
            top: 0;
            z-index: 1030;
            height: 68px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 22px;
            background: rgba(255, 255, 255, 0.72);
            border-bottom: 1px solid rgba(15, 23, 42, 0.06);
            backdrop-filter: blur(18px);
            -webkit-backdrop-filter: blur(18px);
            box-shadow: 0 8px 30px rgba(15, 23, 42, 0.04);
        }

        .brand-wrap {
            display: flex;
            align-items: center;
            gap: 12px;
            min-width: 0;
        }

        .brand-mark {
            width: 48px;
            height: 48px;
            border-radius: 50%;
            display: grid;
            place-items: center;
            color: #fff;
            background: #fff;
            border: 1px solid rgba(41, 71, 155, 0.20);
            box-shadow: 0 10px 24px rgba(41, 71, 155, 0.16);
            flex: 0 0 auto;
            overflow: hidden;
        }

        .brand-mark img { width: 100%; height: 100%; object-fit: contain; display: block; }

        .brand-text {
            line-height: 1.1;
            min-width: 0;
        }

            .brand-text .title {
                font-family: "Be Vietnam Pro", "Segoe UI", sans-serif;
                font-size: 1rem;
                font-weight: 900;
                letter-spacing: .02em;
                white-space: nowrap;
                overflow: hidden;
                text-overflow: ellipsis;
            }

            .brand-text .subtitle {
                font-family: "Be Vietnam Pro", "Segoe UI", sans-serif;
                font-size: 0.78rem;
                font-weight: 700;
                color: var(--muted);
            }

        .topbar-actions {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .topbar-pill {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 8px 12px;
            border-radius: 999px;
            border: 1px solid rgba(79, 70, 229, 0.14);
            background: rgba(255, 255, 255, 0.68);
            color: var(--text);
            text-decoration: none;
            transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
        }

            .topbar-pill:hover {
                transform: translateY(-1px);
                border-color: rgba(79, 70, 229, 0.22);
                box-shadow: 0 10px 24px rgba(79, 70, 229, 0.10);
            }

        .icon-button {
            position: relative;
            width: 42px;
            height: 42px;
            display: inline-grid;
            place-items: center;
            border: 1px solid rgba(15, 23, 42, 0.08);
            border-radius: 14px;
            background: rgba(255, 255, 255, 0.78);
            color: #334155;
            text-decoration: none;
            transition: transform 0.2s ease, box-shadow 0.2s ease, color 0.2s ease, border-color 0.2s ease;
        }

            .icon-button:hover {
                transform: translateY(-1px);
                color: var(--primary);
                border-color: rgba(79, 70, 229, 0.18);
                box-shadow: 0 12px 26px rgba(15, 23, 42, 0.08);
            }

        .badge-dot {
            position: absolute;
            top: 7px;
            right: 7px;
            width: 9px;
            height: 9px;
            border-radius: 50%;
            background: #ef4444;
            box-shadow: 0 0 0 3px rgba(255, 255, 255, 0.95);
        }

        .user-pill {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            padding: 7px 12px 7px 7px;
            border-radius: 999px;
            border: 1px solid rgba(15, 23, 42, 0.08);
            background: rgba(255, 255, 255, 0.78);
            text-decoration: none;
            color: var(--text);
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }

            .user-pill:hover {
                transform: translateY(-1px);
                box-shadow: 0 12px 26px rgba(15, 23, 42, 0.08);
            }

        .avatar-mini {
            width: 28px;
            height: 28px;
            border-radius: 50%;
            display: grid;
            place-items: center;
            background: linear-gradient(135deg, #dbeafe, #eef2ff);
            color: var(--primary);
            flex: 0 0 auto;
        }

        .mobile-menu-btn {
            width: 42px;
            height: 42px;
            display: inline-grid;
            place-items: center;
            border: 1px solid rgba(15, 23, 42, 0.08);
            border-radius: 14px;
            background: rgba(255, 255, 255, 0.78);
            color: #334155;
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }

            .mobile-menu-btn:hover {
                transform: translateY(-1px);
                box-shadow: 0 12px 26px rgba(15, 23, 42, 0.08);
            }

        .admin-shell {
            display: flex;
            min-height: calc(100vh - 68px);
        }

        .admin-sidebar {
            width: 290px;
            flex: 0 0 290px;
            padding: 20px 15px;
            background: rgba(255, 255, 255, 0.66);
            border-right: 1px solid rgba(15, 23, 42, 0.06);
            backdrop-filter: blur(18px);
            -webkit-backdrop-filter: blur(18px);
            transition: width 0.28s ease, flex-basis 0.28s ease, transform 0.28s ease, opacity 0.28s ease;
            overflow-y: auto;
        }

            .admin-sidebar.collapsed {
                width: 88px;
                flex-basis: 88px;
                overflow: visible;
            }

        .admin-shell.sidebar-collapsed .admin-main {
            margin-left: 0;
        }

        .sidebar-group {
            margin-bottom: 20px;
        }

        .sidebar-group-title {
            font-size: 0.76rem;
            font-weight: 700;
            color: #64748b;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            margin: 8px 10px 10px;
        }

        .sidebar-link,
        .sidebar-group-toggle {
            position: relative;
            width: 100%;
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 11px 12px;
            margin-bottom: 6px;
            border-radius: 14px;
            border: 1px solid transparent;
            text-decoration: none;
            color: #334155;
            background: transparent;
            transition: background 0.2s ease, transform 0.2s ease, color 0.2s ease, border-color 0.2s ease;
        }

            .sidebar-link:hover,
            .sidebar-group-toggle:hover {
                background: rgba(79, 70, 229, 0.06);
                color: var(--primary);
                transform: translateX(2px);
            }

            .sidebar-link.active {
                background: linear-gradient(135deg, var(--app-primary, #2563eb), var(--app-primary-2, #4f46e5));
                color: #fff;
                border-color: rgba(255,255,255,.22);
                box-shadow: 0 14px 30px rgba(37, 99, 235, 0.28), inset 0 0 0 1px rgba(255,255,255,.12);
            }

                .sidebar-link.active::before {
                    content: "";
                    position: absolute;
                    left: 7px;
                    top: 50%;
                    width: 4px;
                    height: 58%;
                    border-radius: 999px;
                    transform: translateY(-50%);
                    background: #fff;
                    box-shadow: 0 0 0 3px rgba(255,255,255,.18);
                }

            .sidebar-link i,
            .sidebar-group-toggle i {
                width: 18px;
                text-align: center;
                flex: 0 0 18px;
            }

        .sidebar-text {
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .admin-sidebar.collapsed .sidebar-group-title,
        .admin-sidebar.collapsed .sidebar-text,
        .admin-sidebar.collapsed .sidebar-chevron {
            opacity: 0;
            width: 0;
            pointer-events: none;
        }

        .admin-sidebar.collapsed .sidebar-link,
        .admin-sidebar.collapsed .sidebar-group-toggle {
            justify-content: center;
            padding-left: 0;
            padding-right: 0;
        }

        .admin-sidebar.collapsed .sidebar-link::after,
        .admin-sidebar.collapsed .sidebar-group-toggle::after {
            content: attr(data-title);
            position: absolute;
            left: calc(100% + 12px);
            top: 50%;
            transform: translateY(-50%) translateX(-4px);
            opacity: 0;
            pointer-events: none;
            white-space: nowrap;
            padding: 8px 11px;
            border-radius: 12px;
            background: #0f172a;
            color: #fff;
            font-size: .84rem;
            font-weight: 600;
            box-shadow: 0 14px 30px rgba(15,23,42,.22);
            z-index: 1200;
            transition: opacity .16s ease, transform .16s ease;
        }

        .admin-sidebar.collapsed .sidebar-link::before,
        .admin-sidebar.collapsed .sidebar-group-toggle::before {
            content: "";
            position: absolute;
            left: calc(100% + 5px);
            top: 50%;
            transform: translateY(-50%);
            border-top: 6px solid transparent;
            border-bottom: 6px solid transparent;
            border-right: 7px solid #0f172a;
            opacity: 0;
            pointer-events: none;
            z-index: 1201;
            transition: opacity .16s ease;
        }

        .admin-sidebar.collapsed .sidebar-link:hover::after,
        .admin-sidebar.collapsed .sidebar-link:hover::before,
        .admin-sidebar.collapsed .sidebar-group-toggle:hover::after,
        .admin-sidebar.collapsed .sidebar-group-toggle:hover::before {
            opacity: 1;
            transform: translateY(-50%) translateX(0);
        }

        .sidebar-group-toggle {
            border: 0;
            outline: none;
        }

        .sidebar-chevron {
            margin-left: auto;
            font-size: 0.8rem;
            opacity: 0.7;
        }

        .admin-main {
            flex: 1 1 auto;
            min-width: 0;
            padding: 16px 14px 24px;
            transition: margin-left 0.28s ease;
        }

        .admin-content-card {
            background: rgba(255, 255, 255, 0.86);
            border-radius: 24px;
            border: 1px solid rgba(79, 70, 229, 0.08);
            box-shadow: var(--shadow);
            backdrop-filter: blur(14px);
            -webkit-backdrop-filter: blur(14px);
            padding: 18px;
        }

        .admin-shell.no-sidebar {
            display: block;
        }

            .admin-shell.no-sidebar .admin-main {
                margin-left: 0 !important;
                padding-left: 18px;
                padding-right: 18px;
            }

        .dropdown-menu {
            border: 1px solid rgba(15, 23, 42, 0.08);
            box-shadow: 0 18px 40px rgba(15, 23, 42, 0.12);
            border-radius: 16px;
            padding: 8px;
        }

        .dropdown-item {
            border-radius: 12px;
            padding-top: 10px;
            padding-bottom: 10px;
        }

            .dropdown-item:active {
                background: var(--primary);
            }

        .offcanvas {
            border: 0;
            background: rgba(255, 255, 255, 0.92);
            backdrop-filter: blur(18px);
            -webkit-backdrop-filter: blur(18px);
        }

            .offcanvas .sidebar-link {
                justify-content: flex-start;
            }

        @@media (max-width: 991.98px) {
            .app-topbar {
                padding: 0 14px;
            }

            .brand-text .subtitle {
                display: none;
            }

            .admin-shell {
                display: block;
            }

            .admin-sidebar {
                display: none;
            }

            .admin-main {
                margin-left: 0;
                padding: 18px 12px 26px;
            }

            .admin-content-card {
                padding: 22px;
                border-radius: 22px;
            }
        }

        @@media (max-width: 575.98px) {
            .app-topbar {
                height: 64px;
            }

            .brand-mark {
                width: 36px;
                height: 36px;
                border-radius: 50%;
            }

            .brand-text .title {
                font-size: 0.94rem;
            }

            .icon-button,
            .mobile-menu-btn {
                width: 40px;
                height: 40px;
            }

            .admin-main {
                padding: 16px 10px 22px;
            }

            .admin-content-card {
                padding: 18px;
            }
        }
    </style>
</head>

<body class="app-shell-body">
    <header class="app-topbar">
        <div class="brand-wrap">
            @if (showSidebar)
            {
                <button class="mobile-menu-btn d-lg-none" type="button"
                        data-bs-toggle="offcanvas"
                        data-bs-target="#roleMobileMenu"
                        aria-label="Mở menu">
                    <i class="bi bi-list fs-4"></i>
                </button>

                <button class="mobile-menu-btn d-none d-lg-inline-grid" type="button" id="roleSidebarToggle" aria-label="Ẩn hiện menu nghiệp vụ">
                    <i class="bi bi-layout-sidebar-inset"></i>
                </button>
            }

            <a asp-area="" asp-controller="Dashboard" asp-action="Index" class="brand-mark text-decoration-none" aria-label="Trang chủ">
                <img src="~/img/ntu-logo.svg" asp-append-version="true" alt="Logo Đại học Nha Trang" />
            </a>

            <div class="brand-text">
                <div class="title">TRƯỜNG ĐẠI HỌC NHA TRANG</div>
                <div class="subtitle">Hệ thống phân công giám thị coi thi</div>
            </div>
        </div>

        <div class="topbar-actions">
            <a asp-area="" asp-controller="Dashboard" asp-action="Index" aria-label="Trang chủ" class="topbar-pill d-none d-md-inline-flex">
                <i class="bi bi-house-door"></i>
                <span>Home</span>
            </a>

            <button class="theme-toggle-btn" type="button" id="themeToggle" aria-label="Đổi giao diện sáng tối" title="Đổi giao diện sáng/tối">
                <i class="bi bi-moon-stars theme-icon-dark"></i>
                <i class="bi bi-sun theme-icon-light"></i>
                <span class="d-none d-xl-inline theme-toggle-text">Dark</span>
            </button>

            @await Html.PartialAsync("_NotificationBell")

            <div class="dropdown">
                <a class="user-pill dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-label="Tài khoản" aria-expanded="false">
                    <span class="avatar-mini">
                        @if (!string.IsNullOrWhiteSpace(currentProfile?.Avt))
                        {
                            <img src="@currentProfile.Avt" alt="Ảnh đại diện" />
                        }
                        else
                        {
                            <span>@currentInitial</span>
                        }
                    </span>
                    <span class="d-none d-md-inline fw-semibold">@(string.IsNullOrWhiteSpace(currentName) ? User.Identity?.Name : currentName)</span>
                </a>

                <ul class="dropdown-menu dropdown-menu-end">
                    <li>
                        <a class="dropdown-item" asp-area="" asp-controller="Profile" asp-action="Index">
                            <i class="bi bi-person me-2"></i>Thông tin cá nhân
                        </a>
                    </li>
                    <li>
                        <a class="dropdown-item" asp-area="" asp-controller="Profile" asp-action="ChangePassword">
                            <i class="bi bi-key me-2"></i>Đổi mật khẩu
                        </a>
                    </li>
                    <li><hr class="dropdown-divider"></li>
                    <li>
                        <form asp-area="" asp-controller="Account" asp-action="Logout" method="post" class="px-2">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="dropdown-item text-danger">
                                <i class="bi bi-box-arrow-right me-2"></i>Đăng xuất
                            </button>
                        </form>
                    </li>
                </ul>
            </div>
        </div>
    </header>

    <div class="admin-shell @(showSidebar ? "" : "no-sidebar")" id="roleShell">
        @if (showSidebar)
        {
            <aside class="admin-sidebar" id="roleSidebar">
                <nav>
                    <div class="sidebar-group">
                        <div class="sidebar-group-title">Nghiệp vụ chính</div>

                        <a asp-area="" asp-controller="Dashboard" asp-action="Index" aria-label="Tổng quan" title="Tổng quan" data-title="Tổng quan" class="sidebar-link @(IsActive("Dashboard") ? "active" : "")">
                            <i class="bi bi-grid-1x2"></i><span class="sidebar-text">Tổng quan</span>
                        </a>

                        <a asp-area="" asp-controller="ExamSchedule" asp-action="Index" aria-label="Lịch thi" title="Lịch thi" data-title="Lịch thi" class="sidebar-link @(IsActive("ExamSchedule") ? "active" : "")">
                            <i class="bi bi-calendar2-week"></i><span class="sidebar-text">Lịch thi</span>
                        </a>

                        <a asp-area="" asp-controller="Statistics" asp-action="Index" aria-label="Thống kê" title="Thống kê" data-title="Thống kê" class="sidebar-link @(IsActive("Statistics") ? "active" : "")">
                            <i class="bi bi-bar-chart-line"></i><span class="sidebar-text">Thống kê</span>
                        </a>

                        @if (User.IsInRole("Giảng viên"))
                        {
                            <a asp-area="Lecturer" asp-controller="InvigilatorResponse" asp-action="Index" asp-route-status="Chưa phản hồi" aria-label="Xác nhận coi thi" title="Xác nhận coi thi" data-title="Xác nhận coi thi" class="sidebar-link @(IsActive("InvigilatorResponse") ? "active" : "")">
                                <i class="bi bi-check2-square"></i><span class="sidebar-text">Xác nhận coi thi</span>
                            </a>
                        }

                        @if (User.IsInRole("Trưởng khoa") || User.IsInRole("Thư ký khoa"))
                        {
                            <a asp-area="Secretary" asp-controller="ExamScheduleApproval" asp-action="Index" aria-label="Duyệt lịch thi" title="Duyệt lịch thi" data-title="Duyệt lịch thi" class="sidebar-link @(IsActive("ExamScheduleApproval") ? "active" : "")">
                                <i class="bi bi-check2-circle"></i><span class="sidebar-text">Duyệt lịch thi</span>
                            </a>
                        }

                        @if (User.IsInRole("Thư ký khoa"))
                        {
                            <a asp-area="Secretary" asp-controller="AutoAssignment" asp-action="Index" aria-label="Tự động phân công" title="Tự động phân công" data-title="Tự động phân công" class="sidebar-link @(IsActive("AutoAssignment") ? "active" : "")">
                                <i class="bi bi-magic"></i><span class="sidebar-text">Tự động phân công</span>
                            </a>
                            <a asp-area="Secretary" asp-controller="InvigilatorSubstitution" asp-action="Index" aria-label="Đề xuất thay thế" title="Đề xuất thay thế" data-title="Đề xuất thay thế" class="sidebar-link @(IsActive("InvigilatorSubstitution") ? "active" : "")">
                                <i class="bi bi-arrow-left-right"></i><span class="sidebar-text">Đề xuất thay thế</span>
                            </a>
                        }

                        <a asp-area="" asp-controller="BusySlot" asp-action="Index" aria-label="Lịch bận" title="Lịch bận" data-title="Lịch bận" class="sidebar-link @(IsActive("BusySlot") ? "active" : "")">
                            <i class="bi bi-calendar-x"></i><span class="sidebar-text">Lịch bận</span>
                        </a>

                        <a asp-area="" asp-controller="Notification" asp-action="Index" aria-label="Thông báo" title="Thông báo" data-title="Thông báo" class="sidebar-link @(IsActive("Notification") ? "active" : "")">
                            <i class="bi bi-bell"></i><span class="sidebar-text">Thông báo</span>
                        </a>
                    </div>

                    <div class="sidebar-group">
                        <div class="sidebar-group-title">Tài khoản</div>
                        <a asp-area="" asp-controller="Profile" asp-action="Index" aria-label="Hồ sơ cá nhân" title="Hồ sơ cá nhân" data-title="Hồ sơ cá nhân" class="sidebar-link @(IsActive("Profile") ? "active" : "")">
                            <i class="bi bi-person-badge"></i><span class="sidebar-text">Hồ sơ cá nhân</span>
                        </a>
                    </div>
                </nav>
            </aside>
        }

        <main class="admin-main @(showSidebar ? "" : "full-width")">
            @if (showSidebar)
            {
                <div class="admin-content-card">
                    @await Html.PartialAsync("_Notification")
                    @RenderBody()
                </div>
            }
            else
            {
                @await Html.PartialAsync("_Notification")
                @RenderBody()
            }
        </main>
    </div>

    @RenderSection("PageModals", required: false)

    @if (showSidebar)
    {
        <div class="offcanvas offcanvas-start" tabindex="-1" id="roleMobileMenu">
            <div class="offcanvas-header border-bottom">
                <div class="d-flex align-items-center gap-2">
                    <span class="brand-mark mobile-offcanvas-logo"><img src="~/img/ntu-logo.svg" asp-append-version="true" alt="Logo Đại học Nha Trang" /></span>
                    <div>
                        <h5 class="mb-1">TRƯỜNG ĐẠI HỌC NHA TRANG</h5>
                        <div class="small text-muted">Hệ thống phân công giám thị coi thi - @roleName</div>
                    </div>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="offcanvas"></button>
            </div>

            <div class="offcanvas-body">
                <a asp-area="" asp-controller="Dashboard" asp-action="Index" class="sidebar-link mb-2">
                    <i class="bi bi-grid-1x2"></i><span>Tổng quan</span>
                </a>

                <a asp-area="" asp-controller="ExamSchedule" asp-action="Index" class="sidebar-link mb-2">
                    <i class="bi bi-calendar2-week"></i><span>Lịch thi</span>
                </a>

                <a asp-area="" asp-controller="Statistics" asp-action="Index" class="sidebar-link mb-2">
                    <i class="bi bi-bar-chart-line"></i><span>Thống kê</span>
                </a>

                @if (User.IsInRole("Giảng viên"))
                {
                    <a asp-area="Lecturer" asp-controller="InvigilatorResponse" asp-action="Index" class="sidebar-link mb-2">
                        <i class="bi bi-check2-square"></i><span>Xác nhận coi thi</span>
                    </a>
                }

                @if (User.IsInRole("Trưởng khoa") || User.IsInRole("Thư ký khoa"))
                {
                    <a asp-area="Secretary" asp-controller="ExamScheduleApproval" asp-action="Index" class="sidebar-link mb-2">
                        <i class="bi bi-check2-circle"></i><span>Duyệt lịch thi</span>
                    </a>
                }

                @if (User.IsInRole("Thư ký khoa"))
                {
                    <a asp-area="Secretary" asp-controller="AutoAssignment" asp-action="Index" class="sidebar-link mb-2">
                        <i class="bi bi-magic"></i><span>Tự động phân công</span>
                    </a>
                    <a asp-area="Secretary" asp-controller="InvigilatorSubstitution" asp-action="Index" class="sidebar-link mb-2">
                        <i class="bi bi-arrow-left-right"></i><span>Đề xuất thay thế</span>
                    </a>
                }

                <a asp-area="" asp-controller="BusySlot" asp-action="Index" class="sidebar-link mb-2">
                    <i class="bi bi-calendar-x"></i><span>Lịch bận</span>
                </a>

                <a asp-area="" asp-controller="Notification" asp-action="Index" class="sidebar-link mb-2">
                    <i class="bi bi-bell"></i><span>Thông báo</span>
                </a>

                <a asp-area="" asp-controller="Profile" asp-action="Index" class="sidebar-link mb-2">
                    <i class="bi bi-person-badge"></i><span>Hồ sơ cá nhân</span>
                </a>
            </div>
        </div>
    }

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @await Html.PartialAsync("_ValidationScriptsPartial")
    <script src="~/js/notification.js" asp-append-version="true"></script>
    <script src="~/lib/microsoft/signalr/signalr.min.js"></script>
    <script src="~/js/notification-center.js" asp-append-version="true"></script>
    <script src="~/js/theme-toggle.js" asp-append-version="true"></script>

    @if (showSidebar)
    {
        <script>
            (function () {
                const shell = document.getElementById('roleShell');
                const sidebar = document.getElementById('roleSidebar');
                const toggle = document.getElementById('roleSidebarToggle');
                const key = 'role-sidebar-collapsed';
                const scrollKey = 'role-sidebar-scroll';

                if (!shell || !sidebar || !toggle) return;

                if (localStorage.getItem(key) === '1') {
                    shell.classList.add('sidebar-collapsed');
                    sidebar.classList.add('collapsed');
                }

                const activeItem = sidebar.querySelector('.sidebar-link.active');
                const savedScroll = Number(localStorage.getItem(scrollKey));
                if (Number.isFinite(savedScroll) && savedScroll > 0) {
                    sidebar.scrollTop = savedScroll;
                }

                if (activeItem) {
                    requestAnimationFrame(function () {
                        activeItem.scrollIntoView({ block: 'nearest' });
                        localStorage.setItem(scrollKey, sidebar.scrollTop.toString());
                    });
                }

                sidebar.addEventListener('scroll', function () {
                    localStorage.setItem(scrollKey, sidebar.scrollTop.toString());
                }, { passive: true });

                toggle.addEventListener('click', function () {
                    shell.classList.toggle('sidebar-collapsed');
                    sidebar.classList.toggle('collapsed');
                    localStorage.setItem(key, shell.classList.contains('sidebar-collapsed') ? '1' : '0');
                });
            })();
        </script>
    }

    @RenderSection("Scripts", required: false)
    @await Html.PartialAsync("_DeleteModal")
</body>
</html>
