@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@{
    var antiforgeryToken = Antiforgery.GetAndStoreTokens(Context).RequestToken;
    var controller = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var area = ViewContext.RouteData.Values["area"]?.ToString() ?? "";
    bool IsActive(string c, string? a = null) => string.Equals(controller, c, StringComparison.OrdinalIgnoreCase) && (a == null || string.Equals(area, a, StringComparison.OrdinalIgnoreCase));
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="request-verification-token" content="@antiforgeryToken" />
    <title>@ViewData["Title"] - ExamInvigilationManagement</title>
    <script>
        (function () {
            var key = 'exam-ui-theme';
            var theme = localStorage.getItem(key) || (window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
            document.documentElement.setAttribute('data-theme', theme);
        })();
    </script>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/app_shell.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin_index.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin_create_edit.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/notification.css" asp-append-version="true" />
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
</head>
<body class="app-shell-body">
    <header class="app-topbar">
        <div class="brand-wrap">
            <button class="mobile-menu-btn d-lg-none" type="button" data-bs-toggle="offcanvas" data-bs-target="#adminMobileMenu" aria-label="Mở menu">
                <i class="bi bi-list fs-4"></i>
            </button>
            <button class="mobile-menu-btn d-none d-lg-inline-grid" type="button" id="sidebarToggle" aria-label="Ẩn hiện menu quản trị">
                <i class="bi bi-layout-sidebar-inset"></i>
            </button>
            <a asp-area="" asp-controller="Dashboard" asp-action="Index" class="brand-mark text-decoration-none" aria-label="Dashboard">
                <i class="bi bi-shield-check"></i>
            </a>
            <div class="brand-text">
                <div class="title">Admin Console</div>
                <div class="subtitle">Quản trị dữ liệu nền và vận hành hệ thống</div>
            </div>
        </div>

        <div class="topbar-actions">
            <button class="theme-toggle-btn" type="button" id="themeToggle" aria-label="Đổi giao diện sáng tối" title="Đổi giao diện sáng/tối">
                <i class="bi bi-moon-stars theme-icon-dark"></i>
                <i class="bi bi-sun theme-icon-light"></i>
                <span class="d-none d-xl-inline theme-toggle-text">Dark</span>
            </button>
            @await Html.PartialAsync("_NotificationBell")
            <div class="dropdown">
                <a class="user-pill dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-label="Tài khoản" aria-expanded="false">
                    <span class="avatar-mini"><i class="bi bi-person"></i></span>
                    <span class="d-none d-md-inline fw-semibold">@User.Identity?.Name</span>
                </a>
                <ul class="dropdown-menu dropdown-menu-end">
                    <li><a class="dropdown-item" asp-area="" asp-controller="Profile" asp-action="Index"><i class="bi bi-person me-2"></i>Thông tin cá nhân</a></li>
                    <li><a class="dropdown-item" asp-area="" asp-controller="Profile" asp-action="ChangePassword"><i class="bi bi-key me-2"></i>Đổi mật khẩu</a></li>
                    <li><hr class="dropdown-divider"></li>
                    <li>
                        <form asp-area="" asp-controller="Account" asp-action="Logout" method="post" class="px-2">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="dropdown-item text-danger"><i class="bi bi-box-arrow-right me-2"></i>Đăng xuất</button>
                        </form>
                    </li>
                </ul>
            </div>
        </div>
    </header>

    <div class="admin-shell" id="adminShell">
        <aside class="admin-sidebar" id="adminSidebar">
            <nav>
                <div class="sidebar-group">
                    <div class="sidebar-group-title">Tổng quan</div>
                    <a asp-area="" asp-controller="Dashboard" asp-action="Index" aria-label="Dashboard" class="sidebar-link @(IsActive("Dashboard") ? "active" : "")">
                        <i class="bi bi-grid-1x2"></i><span class="sidebar-text">Dashboard</span>
                    </a>
                    <a asp-area="" asp-controller="Notification" asp-action="Index" aria-label="Thông báo" class="sidebar-link @(IsActive("Notification") ? "active" : "")">
                        <i class="bi bi-bell"></i><span class="sidebar-text">Thông báo</span>
                    </a>
                </div>

                <div class="sidebar-group">
                    <div class="sidebar-group-title">Tổ chức & tài khoản</div>
                    <button class="sidebar-group-toggle" type="button" data-bs-toggle="collapse" data-bs-target="#navOrg" aria-expanded="true" aria-label="Danh mục tổ chức">
                        <i class="bi bi-diagram-3"></i><span class="sidebar-text">Danh mục tổ chức</span><i class="bi bi-chevron-down sidebar-chevron"></i>
                    </button>
                    <div class="collapse show sidebar-subnav" id="navOrg">
                        <a asp-area="Admin" asp-controller="Faculty" asp-action="Index" aria-label="Khoa" class="sidebar-link @(IsActive("Faculty", "Admin") ? "active" : "")"><i class="bi bi-mortarboard"></i><span class="sidebar-text">Khoa</span></a>
                        <a asp-area="Admin" asp-controller="Information" asp-action="Index" aria-label="Thông tin cá nhân" class="sidebar-link @(IsActive("Information", "Admin") ? "active" : "")"><i class="bi bi-person-lines-fill"></i><span class="sidebar-text">Thông tin cá nhân</span></a>
                        <a asp-area="Admin" asp-controller="User" asp-action="Index" aria-label="Tài khoản" class="sidebar-link @(IsActive("User", "Admin") ? "active" : "")"><i class="bi bi-people"></i><span class="sidebar-text">Tài khoản</span></a>
                        <a asp-area="Admin" asp-controller="Role" asp-action="Index" aria-label="Vai trò" class="sidebar-link @(IsActive("Role", "Admin") ? "active" : "")"><i class="bi bi-shield-lock"></i><span class="sidebar-text">Vai trò</span></a>
                        <a asp-area="Admin" asp-controller="Position" asp-action="Index" aria-label="Chức vụ" class="sidebar-link @(IsActive("Position", "Admin") ? "active" : "")"><i class="bi bi-briefcase"></i><span class="sidebar-text">Chức vụ</span></a>
                    </div>
                </div>

                <div class="sidebar-group">
                    <div class="sidebar-group-title">Cấu trúc đào tạo</div>
                    <button class="sidebar-group-toggle" type="button" data-bs-toggle="collapse" data-bs-target="#navAcademic" aria-expanded="true" aria-label="Cây năm học">
                        <i class="bi bi-calendar-range"></i><span class="sidebar-text">Cây năm học</span><i class="bi bi-chevron-down sidebar-chevron"></i>
                    </button>
                    <div class="collapse show sidebar-subnav" id="navAcademic">
                        <a asp-area="Admin" asp-controller="AcademyYear" asp-action="Index" aria-label="Năm học / học kỳ / ca thi" class="sidebar-link @(IsActive("AcademyYear", "Admin") || IsActive("Semester", "Admin") || IsActive("Period", "Admin") || IsActive("Session", "Admin") || IsActive("Slot", "Admin") ? "active" : "")"><i class="bi bi-calendar3"></i><span class="sidebar-text">Năm học / học kỳ / ca thi</span></a>
                        <a asp-area="Admin" asp-controller="Subject" asp-action="Index" aria-label="Môn học" class="sidebar-link @(IsActive("Subject", "Admin") ? "active" : "")"><i class="bi bi-book"></i><span class="sidebar-text">Môn học</span></a>
                        <a asp-area="Admin" asp-controller="CourseOffering" asp-action="Index" aria-label="Học phần mở" class="sidebar-link @(IsActive("CourseOffering", "Admin") ? "active" : "")"><i class="bi bi-journal-bookmark"></i><span class="sidebar-text">Học phần mở</span></a>
                    </div>
                </div>

                <div class="sidebar-group">
                    <div class="sidebar-group-title">Lịch thi & cơ sở vật chất</div>
                    <button class="sidebar-group-toggle" type="button" data-bs-toggle="collapse" data-bs-target="#navExam" aria-expanded="true" aria-label="Vận hành lịch thi">
                        <i class="bi bi-clipboard2-check"></i><span class="sidebar-text">Vận hành lịch thi</span><i class="bi bi-chevron-down sidebar-chevron"></i>
                    </button>
                    <div class="collapse show sidebar-subnav" id="navExam">
                        <a asp-area="" asp-controller="ExamSchedule" asp-action="Index" aria-label="Lịch thi" class="sidebar-link @(IsActive("ExamSchedule") ? "active" : "")"><i class="bi bi-table"></i><span class="sidebar-text">Lịch thi</span></a>
                        <a asp-area="Admin" asp-controller="Building" asp-action="Index" aria-label="Giảng đường" class="sidebar-link @(IsActive("Building", "Admin") ? "active" : "")"><i class="bi bi-building"></i><span class="sidebar-text">Giảng đường</span></a>
                        <a asp-area="Admin" asp-controller="Room" asp-action="Index" aria-label="Phòng thi" class="sidebar-link @(IsActive("Room", "Admin") ? "active" : "")"><i class="bi bi-door-open"></i><span class="sidebar-text">Phòng thi</span></a>
                        <a asp-area="" asp-controller="BusySlot" asp-action="Index" aria-label="Lịch bận" class="sidebar-link @(IsActive("BusySlot") ? "active" : "")"><i class="bi bi-calendar-x"></i><span class="sidebar-text">Lịch bận</span></a>
                    </div>
                </div>
            </nav>
        </aside>

        <main class="admin-main">
            <div class="admin-content-card">
                @await Html.PartialAsync("_Notification")
                @RenderBody()
            </div>
        </main>
    </div>
    @RenderSection("PageModals", required: false)
    <div class="offcanvas offcanvas-start admin-mobile-offcanvas" tabindex="-1" id="adminMobileMenu" aria-labelledby="adminMobileMenuLabel">
        <div class="offcanvas-header">
            <div>
                <h5 class="mb-1" id="adminMobileMenuLabel">Admin menu</h5>
                <div class="small text-muted">Điều hướng nhanh</div>
            </div>
            <button type="button" class="btn-close" data-bs-dismiss="offcanvas"></button>
        </div>

        <div class="offcanvas-body p-0">
            <div class="admin-mobile-menu">
                <div class="sidebar-group">
                    <div class="sidebar-group-title">Tổng quan</div>
                    <a asp-area="" asp-controller="Dashboard" asp-action="Index" class="sidebar-link mb-2 @(IsActive("Dashboard") ? "active" : "")">
                        <i class="bi bi-grid-1x2"></i><span class="sidebar-text">Dashboard</span>
                    </a>
                    <a asp-area="" asp-controller="Notification" asp-action="Index" class="sidebar-link mb-2 @(IsActive("Notification") ? "active" : "")">
                        <i class="bi bi-bell"></i><span class="sidebar-text">Thông báo</span>
                    </a>
                </div>

                <div class="sidebar-group">
                    <div class="sidebar-group-title">Tổ chức & tài khoản</div>
                    <button class="sidebar-group-toggle mb-2" type="button" data-bs-toggle="collapse" data-bs-target="#mobileNavOrg" aria-expanded="true">
                        <i class="bi bi-diagram-3"></i><span class="sidebar-text">Danh mục tổ chức</span><i class="bi bi-chevron-down sidebar-chevron"></i>
                    </button>
                    <div class="collapse show sidebar-subnav" id="mobileNavOrg">
                        <a asp-area="Admin" asp-controller="Faculty" asp-action="Index" class="sidebar-link @(IsActive("Faculty", "Admin") ? "active" : "")">
                            <i class="bi bi-mortarboard"></i><span class="sidebar-text">Khoa</span>
                        </a>
                        <a asp-area="Admin" asp-controller="Information" asp-action="Index" class="sidebar-link @(IsActive("Information", "Admin") ? "active" : "")">
                            <i class="bi bi-person-lines-fill"></i><span class="sidebar-text">Thông tin cá nhân</span>
                        </a>
                        <a asp-area="Admin" asp-controller="User" asp-action="Index" class="sidebar-link @(IsActive("User", "Admin") ? "active" : "")">
                            <i class="bi bi-people"></i><span class="sidebar-text">Tài khoản</span>
                        </a>
                        <a asp-area="Admin" asp-controller="Role" asp-action="Index" class="sidebar-link @(IsActive("Role", "Admin") ? "active" : "")">
                            <i class="bi bi-shield-lock"></i><span class="sidebar-text">Vai trò</span>
                        </a>
                        <a asp-area="Admin" asp-controller="Position" asp-action="Index" class="sidebar-link @(IsActive("Position", "Admin") ? "active" : "")">
                            <i class="bi bi-briefcase"></i><span class="sidebar-text">Chức vụ</span>
                        </a>
                    </div>
                </div>

                <div class="sidebar-group">
                    <div class="sidebar-group-title">Cấu trúc đào tạo</div>
                    <button class="sidebar-group-toggle mb-2" type="button" data-bs-toggle="collapse" data-bs-target="#mobileNavAcademic" aria-expanded="true">
                        <i class="bi bi-calendar-range"></i><span class="sidebar-text">Cây năm học</span><i class="bi bi-chevron-down sidebar-chevron"></i>
                    </button>
                    <div class="collapse show sidebar-subnav" id="mobileNavAcademic">
                        <a asp-area="Admin" asp-controller="AcademyYear" asp-action="Index" class="sidebar-link @(IsActive("AcademyYear", "Admin") || IsActive("Semester", "Admin") || IsActive("Period", "Admin") || IsActive("Session", "Admin") || IsActive("Slot", "Admin") ? "active" : "")">
                            <i class="bi bi-calendar3"></i><span class="sidebar-text">Năm học / học kỳ / ca thi</span>
                        </a>
                        <a asp-area="Admin" asp-controller="Subject" asp-action="Index" class="sidebar-link @(IsActive("Subject", "Admin") ? "active" : "")">
                            <i class="bi bi-book"></i><span class="sidebar-text">Môn học</span>
                        </a>
                        <a asp-area="Admin" asp-controller="CourseOffering" asp-action="Index" class="sidebar-link @(IsActive("CourseOffering", "Admin") ? "active" : "")">
                            <i class="bi bi-journal-bookmark"></i><span class="sidebar-text">Học phần mở</span>
                        </a>
                    </div>
                </div>

                <div class="sidebar-group">
                    <div class="sidebar-group-title">Lịch thi & cơ sở vật chất</div>
                    <button class="sidebar-group-toggle mb-2" type="button" data-bs-toggle="collapse" data-bs-target="#mobileNavExam" aria-expanded="true">
                        <i class="bi bi-clipboard2-check"></i><span class="sidebar-text">Vận hành lịch thi</span><i class="bi bi-chevron-down sidebar-chevron"></i>
                    </button>
                    <div class="collapse show sidebar-subnav" id="mobileNavExam">
                        <a asp-area="" asp-controller="ExamSchedule" asp-action="Index" class="sidebar-link @(IsActive("ExamSchedule") ? "active" : "")">
                            <i class="bi bi-table"></i><span class="sidebar-text">Lịch thi</span>
                        </a>
                        <a asp-area="Admin" asp-controller="Building" asp-action="Index" class="sidebar-link @(IsActive("Building", "Admin") ? "active" : "")">
                            <i class="bi bi-building"></i><span class="sidebar-text">Giảng đường</span>
                        </a>
                        <a asp-area="Admin" asp-controller="Room" asp-action="Index" class="sidebar-link @(IsActive("Room", "Admin") ? "active" : "")">
                            <i class="bi bi-door-open"></i><span class="sidebar-text">Phòng thi</span>
                        </a>
                        <a asp-area="" asp-controller="BusySlot" asp-action="Index" class="sidebar-link @(IsActive("BusySlot") ? "active" : "")">
                            <i class="bi bi-calendar-x"></i><span class="sidebar-text">Lịch bận</span>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @await Html.PartialAsync("_ValidationScriptsPartial")
    <script src="~/js/notification.js" asp-append-version="true"></script>
    <script src="~/lib/microsoft/signalr/signalr.min.js"></script>
    <script src="~/js/notification-center.js" asp-append-version="true"></script>
    <script>
        (function () {
            const shell = document.getElementById('adminShell');
            const sidebar = document.getElementById('adminSidebar');
            const toggle = document.getElementById('sidebarToggle');
            const key = 'admin-sidebar-collapsed';
            const scrollKey = 'admin-sidebar-scroll';

            if (!shell || !sidebar || !toggle) return;

            if (localStorage.getItem(key) === '1') {
                shell.classList.add('sidebar-collapsed');
                sidebar.classList.add('collapsed');
            }

            const activeItem = sidebar.querySelector('.sidebar-link.active');
            const savedScroll = Number(localStorage.getItem(scrollKey));
            if (Number.isFinite(savedScroll) && savedScroll > 0) {
                sidebar.scrollTop = savedScroll;
            }

            if (activeItem) {
                requestAnimationFrame(function () {
                    activeItem.scrollIntoView({ block: 'nearest' });
                    localStorage.setItem(scrollKey, sidebar.scrollTop.toString());
                });
            }

            sidebar.addEventListener('scroll', function () {
                localStorage.setItem(scrollKey, sidebar.scrollTop.toString());
            }, { passive: true });

            function syncChildWidth() {
                const openSubnavs = shell.classList.contains('sidebar-collapsed')
                    ? sidebar.querySelectorAll('.sidebar-subnav.collapse.show').length
                    : 0;

                const width = openSubnavs > 0 ? 122 : 88;
                shell.style.setProperty('--collapsed-sidebar-width', width + 'px');
            }

            sidebar.querySelectorAll('.sidebar-subnav.collapse').forEach(function (el) {
                el.addEventListener('shown.bs.collapse', syncChildWidth);
                el.addEventListener('hidden.bs.collapse', syncChildWidth);
            });

            toggle.addEventListener('click', function () {
                shell.classList.toggle('sidebar-collapsed');
                sidebar.classList.toggle('collapsed');
                localStorage.setItem(key, shell.classList.contains('sidebar-collapsed') ? '1' : '0');
                syncChildWidth();
            });

            syncChildWidth();

            // ===== Hover label nổi riêng, không bị clip =====
            let tooltip = null;

            function removeTooltip() {
                if (tooltip) {
                    tooltip.remove();
                    tooltip = null;
                }
            }

            function showTooltip(target) {
                if (!shell.classList.contains('sidebar-collapsed')) return;

                const label =
                    target.getAttribute('aria-label') ||
                    target.querySelector('.sidebar-text')?.textContent?.trim();

                if (!label) return;

                removeTooltip();

                tooltip = document.createElement('div');
                tooltip.className = 'sidebar-flyout-tooltip';
                tooltip.textContent = label;
                document.body.appendChild(tooltip);

                const rect = target.getBoundingClientRect();

                requestAnimationFrame(() => {
                    const tipRect = tooltip.getBoundingClientRect();

                    let left = rect.right + 12;
                    let top = rect.top + (rect.height / 2);

                    if (left + tipRect.width + 12 > window.innerWidth) {
                        left = rect.left - tipRect.width - 12;
                    }

                    if (left < 12) left = 12;

                    const maxTop = window.innerHeight - tipRect.height - 12;
                    top = Math.max(12, Math.min(maxTop, top));

                    tooltip.style.left = left + 'px';
                    tooltip.style.top = top + 'px';
                    tooltip.classList.add('show');
                });
            }

            sidebar.querySelectorAll('.sidebar-link, .sidebar-group-toggle').forEach(function (el) {
                el.addEventListener('mouseenter', function () {
                    showTooltip(el);
                });

                el.addEventListener('mouseleave', removeTooltip);
            });

            sidebar.addEventListener('scroll', removeTooltip);
            window.addEventListener('resize', removeTooltip);
            document.addEventListener('scroll', removeTooltip, true);
        })();
    </script>
    <script src="~/js/theme-toggle.js" asp-append-version="true"></script>
     
    @RenderSection("Scripts", required: false)
    @await Html.PartialAsync("_DeleteModal")
</body>
</html>
