@model ExamInvigilationManagement.Application.DTOs.Admin.Building.BuildingDto

@{
    ViewBag.Subtitle = "Tạo thông tin tòa nhà";
}

<form asp-area="Admin" asp-action="Create" method="post">
    @Html.AntiForgeryToken()
    @* <div asp-validation-summary="All" class="text-danger mb-3"></div> *@

    <div class="form-page">

        @await Html.PartialAsync("_FormHeader")

        <div class="form-card">

            <div class="mb-3">
                <label asp-for="BuildingId" class="form-label">Mã giảng đường</label>
                <input asp-for="BuildingId" class="input-modern" />
                <span asp-validation-for="BuildingId" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="BuildingName" class="form-label">Tên giảng đường</label>
                <input asp-for="BuildingName" class="input-modern" />
                <span asp-validation-for="BuildingName" class="text-danger"></span>
            </div>

            @await Html.PartialAsync("_FormFooter")

        </div>

    </div>

</form>
