@model ExamInvigilationManagement.Application.DTOs.Admin.User.UserDto

@{
    ViewData["Title"] = "Thêm tài khoản";
    ViewBag.Subtitle = "Tạo tài khoản người dùng mới";
}

<form asp-area="Admin" asp-action="Create" method="post" id="userForm">
    @Html.AntiForgeryToken()

    <div class="form-page">
        @await Html.PartialAsync("_FormHeader", "Tạo tài khoản người dùng mới")

        <div class="form-card">

            <div class="form-group">
                <label class="form-label">Tên đăng nhập</label>
                <input asp-for="UserName" class="input-modern" />
                <span asp-validation-for="UserName" class="text-danger d-block mt-1"></span>
            </div>

            <div class="form-group">
                <label class="form-label">Mật khẩu</label>
                <input asp-for="Password" type="password" class="input-modern" />
                <span asp-validation-for="Password" class="text-danger d-block mt-1"></span>
            </div>

            <div class="form-group">
                @await Html.PartialAsync("_LookupField", new ExamInvigilationManagement.ViewModel.LookupFieldViewModel
           {
               Label = "Vai trò",
               InputId = "roleInput",
               HiddenId = "roleId",
               HiddenName = "RoleId",
               MenuId = "roleDropdown",
               Placeholder = "Chọn vai trò...",
               InputClass = "input-modern",
               ShowButton = false
           })
                <span asp-validation-for="RoleId" class="text-danger d-block mt-1"></span>
            </div>

            <div class="form-group">
                @await Html.PartialAsync("_LookupField", new ExamInvigilationManagement.ViewModel.LookupFieldViewModel
           {
               Label = "Thông tin cá nhân",
               InputId = "informationInput",
               HiddenId = "informationId",
               HiddenName = "InformationId",
               MenuId = "informationDropdown",
               Placeholder = "Chọn họ tên...",
               InputClass = "input-modern",
               ShowButton = false
           })
                <span asp-validation-for="InformationId" class="text-danger d-block mt-1"></span>
            </div>

            <div class="form-group">
                @await Html.PartialAsync("_LookupField", new ExamInvigilationManagement.ViewModel.LookupFieldViewModel
           {
               Label = "Khoa",
               InputId = "facultyInput",
               HiddenId = "facultyId",
               HiddenName = "FacultyId",
               MenuId = "facultyDropdown",
               Placeholder = "Chọn khoa...",
               InputClass = "input-modern",
               ShowButton = false
           })
                <span asp-validation-for="FacultyId" class="text-danger d-block mt-1"></span>
            </div>

            <div class="form-check mb-3">
                <input asp-for="IsActive" class="form-check-input" />
                <label class="form-check-label">Hoạt động</label>
            </div>

            @await Html.PartialAsync("_FormFooter")
        </div>
    </div>
</form>

@section Scripts {
    <script src="~/js/admin_lookup.js"></script>
    <script>
        $(function () {
            AdminLookup.create({
                key: 'user-role-create',
                input: '#roleInput',
                hidden: '#roleId',
                menu: '#roleDropdown',
                url: '@Url.Action("Search", "Role", new { area = "Admin" })',
                queryParam: 'keyword',
                valueField: 'id',
                textField: 'name'
            });

            AdminLookup.create({
                key: 'user-information-create',
                input: '#informationInput',
                hidden: '#informationId',
                menu: '#informationDropdown',
                url: '@Url.Action("Search", "Information", new { area = "Admin" })',
                queryParam: 'keyword',
                valueField: 'id',
                textField: 'fullName'
            });

            AdminLookup.create({
                key: 'user-faculty-create',
                input: '#facultyInput',
                hidden: '#facultyId',
                menu: '#facultyDropdown',
                url: '@Url.Action("Search", "Faculty", new { area = "Admin" })',
                queryParam: 'keyword',
                valueField: 'id',
                textField: 'name'
            });

            $('#userForm').on('submit', function (e) {
                const roleId = ($('#roleId').val() || '').trim();
                const informationId = ($('#informationId').val() || '').trim();

                if (!roleId) {
                    e.preventDefault();
                    $('span[data-valmsg-for="RoleId"]').text('Vui lòng chọn vai trò.');
                }

                if (!informationId) {
                    e.preventDefault();
                    $('span[data-valmsg-for="InformationId"]').text('Vui lòng chọn thông tin cá nhân.');
                }
            });
        });
    </script>
}
