@model ExamInvigilationManagement.Application.DTOs.Admin.User.UserDto

@{
    ViewData["Title"] = "Cập nhật tài khoản";
}

<form asp-area="Admin" asp-action="Edit" method="post" id="userForm">
    @Html.AntiForgeryToken()

    <div class="form-page">
        @await Html.PartialAsync("_FormHeader", "Cập nhật tài khoản người dùng")

        <div class="form-card">

            <input type="hidden" asp-for="Id" />

            <div class="form-group">
                <label class="form-label">Tên đăng nhập</label>
                <input asp-for="UserName" class="input-modern" />
                <span asp-validation-for="UserName" class="text-danger d-block mt-1"></span>
            </div>

            <div class="form-group">
                <label class="form-label">Vai trò</label>
                @await Html.PartialAsync("_LookupField", new ExamInvigilationManagement.ViewModel.LookupFieldViewModel
           {
               Label = null,
               InputId = "roleInput",
               HiddenId = "roleId",
               HiddenName = "RoleId",
               MenuId = "roleDropdown",
               Placeholder = "Chọn vai trò...",
               InputClass = "input-modern",
               ShowButton = false,
               InitialValue = Model.RoleId.ToString(),
               InitialText = Model.RoleName ?? ""
           })
                <span asp-validation-for="RoleId" class="text-danger d-block mt-1"></span>
            </div>

            <div class="form-group">
                <label class="form-label">Thông tin cá nhân</label>
                @await Html.PartialAsync("_LookupField", new ExamInvigilationManagement.ViewModel.LookupFieldViewModel
           {
               Label = null,
               InputId = "informationInput",
               HiddenId = "informationId",
               HiddenName = "InformationId",
               MenuId = "informationDropdown",
               Placeholder = "Chọn họ tên...",
               InputClass = "input-modern",
               ShowButton = false,
               InitialValue = Model.InformationId.ToString(),
               InitialText = Model.FullName ?? ""
           })
                <span asp-validation-for="InformationId" class="text-danger d-block mt-1"></span>
            </div>

            <div class="form-group">
                <label class="form-label">Khoa</label>
                @await Html.PartialAsync("_LookupField", new ExamInvigilationManagement.ViewModel.LookupFieldViewModel
           {
               Label = null,
               InputId = "facultyInput",
               HiddenId = "facultyId",
               HiddenName = "FacultyId",
               MenuId = "facultyDropdown",
               Placeholder = "Chọn khoa...",
               InputClass = "input-modern",
               ShowButton = false,
               InitialValue = Model.FacultyId?.ToString() ?? "",
               InitialText = Model.FacultyName ?? ""
           })
                <span asp-validation-for="FacultyId" class="text-danger d-block mt-1"></span>
            </div>

            <div class="form-check mb-3">
                <input asp-for="IsActive" class="form-check-input" />
                <label class="form-check-label">Hoạt động</label>
            </div>

            @await Html.PartialAsync("_FormFooter")
        </div>
    </div>
</form>

@section Scripts {
    <script src="~/js/admin_lookup.js"></script>
    <script>
        $(function () {
            AdminLookup.create({
                key: 'user-role-edit',
                input: '#roleInput',
                hidden: '#roleId',
                menu: '#roleDropdown',
                url: '@Url.Action("Search", "Role", new { area = "Admin" })',
                queryParam: 'keyword',
                valueField: 'id',
                textField: 'name',
                initialValue: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.RoleId.ToString())),
                initialText: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.RoleName ?? ""))
            });

            AdminLookup.create({
                key: 'user-information-edit',
                input: '#informationInput',
                hidden: '#informationId',
                menu: '#informationDropdown',
                url: '@Url.Action("Search", "Information", new { area = "Admin" })',
                queryParam: 'keyword',
                valueField: 'id',
                textField: 'fullName',
                initialValue: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.InformationId.ToString())),
                initialText: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.FullName ?? ""))
            });

            AdminLookup.create({
                key: 'user-faculty-edit',
                input: '#facultyInput',
                hidden: '#facultyId',
                menu: '#facultyDropdown',
                url: '@Url.Action("Search", "Faculty", new { area = "Admin" })',
                queryParam: 'keyword',
                valueField: 'id',
                textField: 'name',
                initialValue: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.FacultyId?.ToString() ?? "")),
                initialText: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.FacultyName ?? ""))
            });

            $('#userForm').on('submit', function (e) {
                const roleId = ($('#roleId').val() || '').trim();
                const informationId = ($('#informationId').val() || '').trim();

                if (!roleId) {
                    e.preventDefault();
                    $('span[data-valmsg-for="RoleId"]').text('Vui lòng chọn vai trò.');
                }

                if (!informationId) {
                    e.preventDefault();
                    $('span[data-valmsg-for="InformationId"]').text('Vui lòng chọn thông tin cá nhân.');
                }
            });
        });
    </script>
}
