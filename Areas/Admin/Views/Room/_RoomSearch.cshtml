<div class="d-flex flex-wrap align-items-center gap-3">

    <div class="search-modern">
        <i class="bi bi-search"></i>
        <input type="text" class="crud-filter" id="keyword" placeholder="Tên phòng..." />
    </div>

    <div class="lookup-modern position-relative" style="width:260px;">
        <input id="buildingInput" class="form-control" placeholder="Chọn tòa nhà..." autocomplete="off" />
        <div id="buildingDropdown" class="dropdown-menu autocomplete-menu w-100"></div>
        <input type="hidden" id="buildingId" />
    </div>

    <div class="ms-auto">
        <select id="pageSize" class="select-modern">
            <option value="5">5 / trang</option>
            <option value="10">10 / trang</option>
            <option value="20">20 / trang</option>
        </select>
    </div>

</div>
