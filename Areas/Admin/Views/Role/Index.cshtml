@using ExamInvigilationManagement.ViewModel
@model CrudIndexViewModel

@{
    ViewData["Title"] = "Quản lý vai trò";
}

@await Html.PartialAsync("_CrudIndex", Model)

@section Scripts {
    <script src="~/js/admin_crud.js" asp-append-version="true"></script>

    <script>
        $(document).ready(function () {

            CrudPage.init({
                api: '@Url.Action("GetList", "Role", new { area = "Admin" })',
                deleteUrl: '@Url.Action("Delete", "Role", new { area = "Admin" })',
                tableId: '#crudTable',
                filterSelector: '.crud-filter',
                pageSize: '#pageSize',
                deleteName: '#deleteName',
                extraData: function () {
                    return {
                        keyword: $('#searchBox').val()?.trim()
                    };
                }
            });

        });
    </script>
}
