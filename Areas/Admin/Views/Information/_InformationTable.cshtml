@using ExamInvigilationManagement.Common
@model PagedResult<ExamInvigilationManagement.Application.DTOs.Admin.Information.InformationDto>

@{
    int stt = (Model.Page - 1) * Model.PageSize + 1;

    string GetGenderText(string? gender)
    {
        if (string.IsNullOrWhiteSpace(gender)) return "";
        return gender.Trim().ToLower() switch
        {
            "male" => "Nam",
            "female" => "Nữ",
            "other" => "Khác",
            _ => gender
        };
    }
}

<table class="table modern-table wide-table">
    <thead>
        <tr>
            <th class="col-id">STT</th>
            <th class="col-person">Họ tên</th>
            <th class="col-email">Email</th>
            <th class="col-phone">Điện thoại</th>
            <th class="col-name">Địa chỉ</th>
            <th class="col-short">Giới tính</th>
            <th class="col-date">Ngày sinh</th>
            <th class="col-role">Chức vụ</th>
            <th class="col-action">Thao tác</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model.Items)
        {
            <tr>
                <td class="col-id">@stt</td>
                <td class="col-person">@item.LastName @item.FirstName</td>
                <td class="col-email">@item.Email</td>
                <td class="col-phone">@item.Phone</td>
                <td class="col-name">@item.Address</td>
                <td class="col-short">@GetGenderText(item.Gender)</td>
                <td class="col-date">@(item.Dob.HasValue ? item.Dob.Value.ToString("dd/MM/yyyy") : "")</td>
                <td class="col-role">@item.PositionName</td>
                <td class="col-action">
                    <div class="action-group">
                        <a href="/Admin/Information/Edit/@item.Id" class="btn-icon edit">
                            <i class="bi bi-pencil"></i>
                        </a>

                        <a href="#"
                           class="btn-icon delete btn-delete"
                           data-id="@item.Id"
                           data-name="@(item.LastName + " " + item.FirstName)">
                            <i class="bi bi-trash"></i>
                        </a>
                    </div>
                </td>
            </tr>
            stt++;
        }
    </tbody>
</table>

@await Html.PartialAsync("_Pagination", Model)
