<div class="d-flex flex-wrap align-items-center gap-3">

    <div class="search-modern">
        <i class="bi bi-search"></i>
        <input type="text" id="name" class="crud-filter" placeholder="Tên..." />
    </div>

    <div class="search-modern">
        <i class="bi bi-envelope"></i>
        <input type="text" id="email" class="crud-filter" placeholder="Email..." />
    </div>

    <div>
        <select id="gender" class="select-modern crud-filter">
            <option value="">-- Giới tính --</option>
            <option value="Male">Nam</option>
            <option value="Female">Nữ</option>
        </select>
    </div>

    <div>
        <input id="dob" type="date" class="input-modern crud-filter" />
    </div>

    <!-- lookup KHÔNG cần crud-filter -->
    <div class="lookup-modern position-relative" style="width:260px;">
        <input id="positionInput" class="input-modern" placeholder="Chọn chức vụ..." autocomplete="off" />
        <div id="positionDropdown" class="dropdown-menu autocomplete-menu w-100"></div>
        <input type="hidden" id="positionId" />
    </div>

    <div class="ms-auto">
        <select id="pageSize" class="select-modern">
            <option value="5">5 / trang</option>
            <option value="10">10 / trang</option>
            <option value="20">20 / trang</option>
            <option value="50">50 / trang</option>
        </select>
    </div>

</div>
