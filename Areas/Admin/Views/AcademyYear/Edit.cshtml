@model ExamInvigilationManagement.Application.DTOs.Admin.AcademyYear.AcademyYearDetailDto
@using ExamInvigilationManagement.Application.DTOs.Admin.AcademyYear
@using ExamInvigilationManagement.Domain.Enums

@functions {
    bool MatchName(string? dbName, string expected)
    {
        return string.Equals(dbName?.Trim(), expected.Trim(), StringComparison.OrdinalIgnoreCase);
    }

    IReadOnlyList<ExamSlotOptionDto> ExpectedSlots(string sessionName)
    {
        return sessionName switch
        {
            "Sáng" => new[]
            {
                new ExamSlotOptionDto { Name = "Ca 1", TimeStart = new TimeOnly(7, 30), Selected = true },
                new ExamSlotOptionDto { Name = "Ca 2", TimeStart = new TimeOnly(9, 30), Selected = true }
            },
            "Chiều" => new[]
            {
                new ExamSlotOptionDto { Name = "Ca 1", TimeStart = new TimeOnly(13, 30), Selected = true },
                new ExamSlotOptionDto { Name = "Ca 2", TimeStart = new TimeOnly(15, 30), Selected = true }
            },
            "Tối" => new[]
            {
                new ExamSlotOptionDto { Name = "Ca 1", TimeStart = new TimeOnly(18, 30), Selected = true }
            },
            _ => Array.Empty<ExamSlotOptionDto>()
        };
    }
}

@{
    ViewData["Title"] = "Chỉnh sửa năm học";

    var semesterTypes = new[]
    {
        new { Type = SemesterType.Semester1, Label = "Học kỳ 1" },
        new { Type = SemesterType.Semester2, Label = "Học kỳ 2" },
        new { Type = SemesterType.Summer, Label = "Hè" }
    };

    string[] periodsNormal = { "Giữa kỳ", "Cuối kỳ" };
    string[] periodsSummer = { "Cuối kỳ" };
    string[] sessions = { "Sáng", "Chiều", "Tối" };
}

<div class="form-page wide academy-edit-page">
    @await Html.PartialAsync("_FormHeader", "Chỉnh sửa năm học")

    <div class="form-card academy-board">
        <div class="academy-board-head">
            <form asp-area="Admin" asp-controller="AcademyYear" asp-action="Edit" method="post" class="academy-year-form">
                <input type="hidden" name="Id" value="@Model.Id" />
                <label>Năm học</label>
                <input name="Name" value="@Model.Name" class="input-modern" />
                <button class="btn-node-icon edit" type="submit" title="Lưu năm học">
                    <i class="bi bi-check-lg"></i>
                </button>
            </form>
        </div>

        <div class="academy-tree-edit">
            @foreach (var semType in semesterTypes)
            {
                var sem = Model.Semesters.FirstOrDefault(x => x.Type == semType.Type);
                var expectedPeriods = semType.Type == SemesterType.Summer ? periodsSummer : periodsNormal;

                <section class="semester-card-edit">
                    <div class="semester-title-row">
                        <div>
                            <div class="node-label">Học kỳ</div>
                            <div class="node-heading">@semType.Label</div>
                        </div>

                        @if (sem != null)
                        {
                            <form asp-area="Admin" asp-controller="Semester" asp-action="Edit" method="post" class="node-form semester-form">
                                <input type="hidden" name="Id" value="@sem.Id" />
                                <input type="hidden" name="academyYearId" value="@Model.Id" />
                                <input name="Name" value="@sem.Name" class="input-modern compact" />
                                <button class="btn-node-icon edit" type="submit" title="Lưu học kỳ">
                                    <i class="bi bi-check-lg"></i>
                                </button>
                                <a asp-area="Admin" asp-controller="Semester" asp-action="Delete"
                                   asp-route-id="@sem.Id"
                                   asp-route-academyYearId="@Model.Id"
                                   class="btn-node-icon delete" title="Xóa học kỳ">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </form>
                        }
                        else
                        {
                            <form asp-area="Admin" asp-controller="Semester" asp-action="Add" method="post">
                                <input type="hidden" name="academyYearId" value="@Model.Id" />
                                <input type="hidden" name="type" value="@((int)semType.Type)" />
                                <button class="btn-node-add" type="submit">+ Thêm @semType.Label</button>
                            </form>
                        }
                    </div>

                    @if (sem == null)
                    {
                        <div class="empty-child-state">Chưa có học kỳ này. Thêm học kỳ trước để mở các đợt thi bên dưới.</div>
                    }
                    else
                    {
                        <div class="period-grid-edit">
                            @foreach (var pName in expectedPeriods)
                            {
                                var per = sem.Periods.FirstOrDefault(x => MatchName(x.Name, pName));

                                <section class="period-card-edit">
                                    <div class="period-title-row">
                                        <div>
                                            <div class="node-label">Đợt thi</div>
                                            <div class="node-heading">@pName</div>
                                        </div>

                                        @if (per != null)
                                        {
                                            <form asp-area="Admin" asp-controller="Period" asp-action="Edit" method="post" class="node-form period-form">
                                                <input type="hidden" name="Id" value="@per.Id" />
                                                <input type="hidden" name="academyYearId" value="@Model.Id" />
                                                <input name="Name" value="@per.Name" class="input-modern compact" />
                                                <button class="btn-node-icon edit" type="submit" title="Lưu đợt thi">
                                                    <i class="bi bi-check-lg"></i>
                                                </button>
                                                <a asp-area="Admin" asp-controller="Period" asp-action="Delete"
                                                   asp-route-id="@per.Id"
                                                   asp-route-academyYearId="@Model.Id"
                                                   class="btn-node-icon delete" title="Xóa đợt thi">
                                                    <i class="bi bi-trash"></i>
                                                </a>
                                            </form>
                                        }
                                        else
                                        {
                                            <form asp-area="Admin" asp-controller="Period" asp-action="Add" method="post">
                                                <input type="hidden" name="semesterId" value="@sem.Id" />
                                                <input type="hidden" name="academyYearId" value="@Model.Id" />
                                                <input type="hidden" name="name" value="@pName" />
                                                <button class="btn-node-add" type="submit">+ Thêm @pName</button>
                                            </form>
                                        }
                                    </div>

                                    @if (per == null)
                                    {
                                        <div class="empty-child-state">Chưa có đợt thi này. Thêm đợt thi trước để mở các buổi thi.</div>
                                    }
                                    else
                                    {
                                        <div class="session-grid-edit">
                                            @foreach (var sName in sessions)
                                            {
                                                var ses = per.Sessions.FirstOrDefault(x => MatchName(x.Name, sName));
                                                var expectedSlots = ExpectedSlots(sName);

                                                <section class="session-card-edit">
                                                    <div class="session-title-row">
                                                        <div>
                                                            <div class="node-label">Buổi thi</div>
                                                            <div class="node-heading">@sName</div>
                                                        </div>

                                                        @if (ses != null)
                                                        {
                                                            <form asp-area="Admin" asp-controller="Session" asp-action="Edit" method="post" class="node-form session-form">
                                                                <input type="hidden" name="Id" value="@ses.Id" />
                                                                <input type="hidden" name="academyYearId" value="@Model.Id" />
                                                                <input name="Name" value="@ses.Name" class="input-modern compact" />
                                                                <button class="btn-node-icon edit" type="submit" title="Lưu buổi thi">
                                                                    <i class="bi bi-check-lg"></i>
                                                                </button>
                                                                <a asp-area="Admin" asp-controller="Session" asp-action="Delete"
                                                                   asp-route-id="@ses.Id"
                                                                   asp-route-academyYearId="@Model.Id"
                                                                   class="btn-node-icon delete" title="Xóa buổi thi">
                                                                    <i class="bi bi-trash"></i>
                                                                </a>
                                                            </form>
                                                        }
                                                        else
                                                        {
                                                            <form asp-area="Admin" asp-controller="Session" asp-action="Add" method="post">
                                                                <input type="hidden" name="periodId" value="@per.Id" />
                                                                <input type="hidden" name="academyYearId" value="@Model.Id" />
                                                                <input type="hidden" name="name" value="@sName" />
                                                                <button class="btn-node-add" type="submit">+ Thêm @sName</button>
                                                            </form>
                                                        }
                                                    </div>

                                                    @if (ses == null)
                                                    {
                                                        <div class="empty-child-state small">Chưa có buổi @sName.</div>
                                                    }
                                                    else
                                                    {
                                                        <div class="slot-list-edit">
                                                            @foreach (var expectedSlot in expectedSlots)
                                                            {
                                                                var slot = ses.Slots.FirstOrDefault(x => MatchName(x.Name, expectedSlot.Name) && x.TimeStart == expectedSlot.TimeStart);

                                                                if (slot != null)
                                                                {
                                                                    <form asp-area="Admin" asp-controller="Slot" asp-action="Edit" method="post" class="slot-row-edit">
                                                                        <input type="hidden" name="Id" value="@slot.Id" />
                                                                        <input type="hidden" name="academyYearId" value="@Model.Id" />
                                                                        <input name="Name" value="@slot.Name" class="input-modern compact slot-name-input" />
                                                                        <input type="time" name="TimeStart" value="@slot.TimeStart.ToString("HH\\:mm")" class="input-modern compact slot-time-input" />
                                                                        <button class="btn-node-icon edit" type="submit" title="Lưu ca thi">
                                                                            <i class="bi bi-check-lg"></i>
                                                                        </button>
                                                                        <a asp-area="Admin" asp-controller="Slot" asp-action="Delete"
                                                                           asp-route-id="@slot.Id"
                                                                           asp-route-academyYearId="@Model.Id"
                                                                           class="btn-node-icon delete" title="Xóa ca thi">
                                                                            <i class="bi bi-trash"></i>
                                                                        </a>
                                                                    </form>
                                                                }
                                                                else
                                                                {
                                                                    <form asp-area="Admin" asp-controller="Slot" asp-action="Add" method="post" class="slot-row-edit slot-missing-row">
                                                                        <input type="hidden" name="sessionId" value="@ses.Id" />
                                                                        <input type="hidden" name="academyYearId" value="@Model.Id" />
                                                                        <input type="hidden" name="name" value="@expectedSlot.Name" />
                                                                        <input type="hidden" name="timeStart" value="@expectedSlot.TimeStart.ToString("HH\\:mm")" />
                                                                        <span class="missing-slot-text">Thiếu @expectedSlot.Name - @expectedSlot.TimeStart.ToString("HH\\:mm")</span>
                                                                        <button class="btn-node-add" type="submit">+ Thêm ca</button>
                                                                    </form>
                                                                }
                                                            }
                                                        </div>
                                                    }
                                                </section>
                                            }
                                        </div>
                                    }
                                </section>
                            }
                        </div>
                    }
                </section>
            }
        </div>
    </div>
</div>

<style>
    .academy-edit-page .form-card {
        max-width: 100% !important;
    }

    .academy-board {
        padding: 18px;
        border-radius: 18px;
    }

    .academy-board-head {
        border: 1px solid #e2e8f0;
        border-radius: 16px;
        background: linear-gradient(135deg, #f8fafc, #eef2ff);
        padding: 14px;
        margin-bottom: 16px;
    }

    .academy-year-form,
    .node-form,
    .slot-row-edit {
        min-width: 0;
    }

    .academy-year-form {
        display: grid;
        grid-template-columns: auto minmax(220px, 320px) 38px;
        align-items: center;
        gap: 10px;
    }

    .academy-year-form label {
        margin: 0;
        font-weight: 700;
        color: #1e293b;
        white-space: nowrap;
    }

    .academy-year-form input {
        width: 100%;
        max-width: none;
    }

    .academy-tree-edit {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(min(100%, 760px), 1fr));
        gap: 16px;
        align-items: start;
    }

    .semester-card-edit,
    .period-card-edit,
    .session-card-edit {
        min-width: 0;
        overflow: visible;
        border: 1px solid #e2e8f0;
        background: #fff;
    }

    .semester-card-edit {
        border-radius: 18px;
        padding: 14px;
        background: linear-gradient(135deg, rgba(79, 70, 229, .06), #fff 34%);
    }

    .period-card-edit {
        border-radius: 16px;
        padding: 12px;
        background: #f8fafc;
    }

    .session-card-edit {
        border-radius: 14px;
        padding: 10px;
        background: #fff;
    }

    .semester-title-row,
    .period-title-row,
    .session-title-row {
        display: grid;
        grid-template-columns: 1fr;
        gap: 8px;
        align-items: start;
        min-width: 0;
    }

    .node-label {
        color: #64748b;
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .04em;
    }

    .node-heading {
        color: #0f172a;
        font-size: 15px;
        font-weight: 800;
        line-height: 1.2;
    }

    .node-form {
        display: grid;
        grid-template-columns: minmax(180px, 1fr) 38px 38px;
        align-items: center;
        gap: 8px;
        width: 100%;
    }

    .semester-form input,
    .period-form input,
    .session-form input {
        width: 100%;
        min-width: 0;
        max-width: none;
    }

    .period-grid-edit,
    .session-grid-edit {
        display: grid;
        gap: 12px;
        margin-top: 12px;
        align-items: start;
    }

    .period-grid-edit {
        grid-template-columns: repeat(auto-fit, minmax(min(100%, 360px), 1fr));
    }

    .session-grid-edit {
        grid-template-columns: repeat(auto-fit, minmax(min(100%, 330px), 1fr));
    }

    .slot-list-edit {
        display: grid;
        gap: 8px;
        margin-top: 10px;
    }

    .slot-row-edit {
        display: grid;
        grid-template-columns: minmax(120px, 1fr) minmax(118px, 136px) 38px 38px;
        align-items: center;
        gap: 8px;
        width: 100%;
    }

    .slot-name-input,
    .slot-time-input {
        width: 100%;
        min-width: 0;
    }

    .btn-node-icon {
        width: 38px;
        height: 38px;
        min-width: 38px;
        border-radius: 10px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border: 0;
        text-decoration: none;
    }

    .btn-node-icon.edit {
        background: #eef2ff;
        color: #4f46e5;
    }

    .btn-node-icon.delete {
        background: #fee2e2;
        color: #dc2626;
    }

    .btn-node-add {
        border: 1px dashed #94a3b8;
        background: #fff;
        color: #334155;
        border-radius: 999px;
        padding: 7px 12px;
        font-weight: 700;
        font-size: 13px;
        white-space: nowrap;
    }

    .empty-child-state {
        margin-top: 12px;
        border: 1px dashed #cbd5e1;
        background: #f8fafc;
        border-radius: 12px;
        padding: 12px;
        color: #64748b;
        font-size: 13px;
    }

    .empty-child-state.small {
        padding: 9px;
    }

    .slot-missing-row {
        grid-template-columns: minmax(120px, 1fr) auto;
        align-items: center;
        border: 1px dashed #cbd5e1;
        border-radius: 12px;
        padding: 7px;
        background: #f8fafc;
    }

    .missing-slot-text {
        color: #64748b;
        font-size: 13px;
        font-weight: 700;
        min-width: 0;
    }

    @@media (max-width: 768px) {
        .academy-tree-edit,
        .period-grid-edit,
        .session-grid-edit {
            grid-template-columns: 1fr;
        }

        .academy-year-form,
        .semester-title-row,
        .period-title-row,
        .session-title-row,
        .node-form {
            grid-template-columns: 1fr;
        }

        .node-form {
            grid-template-columns: minmax(0, 1fr) 38px 38px;
        }

        .slot-row-edit {
            grid-template-columns: minmax(120px, 1fr) minmax(112px, 128px) 38px 38px;
        }
    }

    @@media (max-width: 520px) {
        .academy-board {
            padding: 12px;
        }

        .semester-card-edit,
        .period-card-edit,
        .session-card-edit {
            padding: 10px;
        }

        .node-form {
            grid-template-columns: minmax(0, 1fr) 38px 38px;
        }

        .slot-row-edit {
            grid-template-columns: minmax(0, 1fr) 118px;
        }

        .slot-row-edit .btn-node-icon {
            width: 100%;
            min-width: 0;
        }

        .slot-missing-row {
            grid-template-columns: 1fr;
        }

        .slot-missing-row .btn-node-add {
            width: 100%;
        }
    }
</style>
