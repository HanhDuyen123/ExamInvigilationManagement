@using ExamInvigilationManagement.Common
@model IPagedResult

<nav class="mt-3">
    <ul class="pagination">

        <li class="page-item @(Model.Page == 1 ? "disabled" : "")">
            <a class="page-link" href="#" onclick="CrudPage.loadData(1)">«</a>
        </li>

        <li class="page-item @(Model.Page == 1 ? "disabled" : "")">
            <a class="page-link" href="#" onclick="CrudPage.loadData(@(Model.Page - 1))">‹</a>
        </li>

        @for (int i = 1; i <= Model.TotalPages; i++)
        {
            <li class="page-item @(i == Model.Page ? "active" : "")">
                <a class="page-link" href="#" onclick="CrudPage.loadData(@i)">@i</a>
            </li>
        }

        <li class="page-item @(Model.Page == Model.TotalPages ? "disabled" : "")">
            <a class="page-link" href="#" onclick="CrudPage.loadData(@(Model.Page + 1))">›</a>
        </li>

        <li class="page-item @(Model.Page == Model.TotalPages ? "disabled" : "")">
            <a class="page-link" href="#" onclick="CrudPage.loadData(@Model.TotalPages)">»</a>
        </li>

    </ul>
</nav>